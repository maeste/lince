// Four-quadrant tiled layout with VoxCode pane.
//
// Same as dashboard-tiled.kdl but pane C runs VoxCode instead of a plain shell.
//
// Requires `agent_layout = "tiled"` in config.toml.
//
// Usage:
//   zellij --layout dashboard-tiled-vox
//
// Structure:
//   ┌──────────────┬─────────────────────┐
//   │ tab-bar (borderless, size=1)       │
//   ├──────────────┬─────────────────────┤
//   │              │                     │  ~70%
//   │   A          │        B            │
//   │  Dashboard   │  Agent viewport     │
//   │  plugin      │  (ASCII art /       │
//   │   40%×70%    │   agent overlay)    │
//   │              │     60%×70%         │
//   ├──────────────┼─────────────────────┤
//   │   C          │        D            │  ~30%
//   │  VoxCode     │      Shell          │
//   │   40%×30%    │     60%×30%         │
//   ├──────────────┴─────────────────────┤
//   │ status-bar (borderless, size=2)    │
//   └────────────────────────────────────┘

layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    tab name="dashboard" {
        pane split_direction="vertical" {
            // Left column — 40%
            pane size="40%" split_direction="horizontal" {
                // A — Dashboard plugin (70% of left column)
                pane size="70%" {
                    plugin location="file:~/.config/zellij/plugins/lince-dashboard.wasm" {
                        config_path "~/.config/lince-dashboard/config.toml"
                    }
                }
                // C — VoxCode (30% of left column)
                pane size="30%" {
                    command "voxcode"
                    args "--use-pipe"
                }
            }
            // Right column — 60%
            pane size="60%" split_direction="horizontal" {
                // B — Agent viewport (70% of right column)
                pane size="70%" {
                    command "lince-viewport-placeholder"
                }
                // D — Shell (30% of right column)
                pane size="30%" {
                }
            }
        }
    }
}
