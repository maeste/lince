// Tiled layout for lince-dashboard — three fixed panes.
//
// Agents are spawned as floating overlays that cover the viewport pane (C)
// when focused. The underlying placeholder shows ASCII art when no agent
// is focused.
//
// Requires `agent_layout = "tiled"` in config.toml.
//
// Usage:
//   lince-tiled
//
// Structure:
//   ┌──────────────┬─────────────────────┐
//   │ tab-bar (borderless, size=1)       │
//   ├──────────────┬─────────────────────┤
//   │              │                     │
//   │   A          │        B            │
//   │  Dashboard   │     Shell           │  ~70%
//   │  plugin      │                     │
//   │   40%×70%    │     60%×100%        │
//   │              │                     │
//   ├──────────────┤                     │
//   │   C          │                     │  ~30%
//   │  Agent       │                     │
//   │  viewport    │                     │
//   │  40%×30%     │                     │
//   ├──────────────┴─────────────────────┤
//   │ status-bar (borderless, size=2)    │
//   └────────────────────────────────────┘

layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    tab name="dashboard" {
        pane split_direction="vertical" {
            // Left column — 40%, split horizontally into A + C
            pane size="40%" split_direction="horizontal" {
                // A — Dashboard plugin (70% of left column)
                pane size="70%" {
                    plugin location="file:~/.config/zellij/plugins/lince-dashboard.wasm" {
                        config_path "~/.config/lince-dashboard/config.toml"
                    }
                }
                // C — Agent viewport (30% of left column)
                // Shows ASCII art placeholder; agent floating overlay covers this on focus.
                pane size="30%" {
                    command "lince-viewport-placeholder"
                }
            }
            // Right column — 60%, full height (B)
            pane size="60%" {
                // B — Shell (full height)
            }
        }
    }
}
