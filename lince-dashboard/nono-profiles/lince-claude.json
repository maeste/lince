{
  "extends": "claude-code",
  "meta": {
    "name": "lince-claude",
    "description": "LINCE sandbox profile for Claude Code"
  },
  "filesystem": {
    "allow": [
      "$WORKDIR"
    ],
    "read": [
      "$HOME/.local/lib"
    ]
  },
  "security": {
    "signal_mode": "allow_same_sandbox"
  }
}
