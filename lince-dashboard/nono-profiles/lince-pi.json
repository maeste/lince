{
  "extends": "default",
  "description": "LINCE sandbox profile for Pi (https://pi.dev)",
  "filesystem": {
    "allow": [
      "$WORKDIR",
      "$HOME/.pi"
    ],
    "read": [
      "$HOME/.local/lib"
    ]
  },
  "environment": {
    "passthrough": [
      "TERM",
      "COLORTERM",
      "TERM_PROGRAM",
      "LANG",
      "LC_ALL",
      "EDITOR",
      "VISUAL",
      "ZELLIJ",
      "ZELLIJ_SESSION_NAME",
      "LINCE_AGENT_ID",
      "ANTHROPIC_API_KEY",
      "ANTHROPIC_BASE_URL",
      "OPENAI_API_KEY",
      "OPENAI_BASE_URL",
      "AZURE_OPENAI_API_KEY",
      "AZURE_OPENAI_BASE_URL",
      "GEMINI_API_KEY",
      "GOOGLE_CLOUD_PROJECT",
      "GOOGLE_CLOUD_LOCATION",
      "DEEPSEEK_API_KEY",
      "MISTRAL_API_KEY",
      "GROQ_API_KEY",
      "CEREBRAS_API_KEY",
      "CLOUDFLARE_API_KEY",
      "CLOUDFLARE_ACCOUNT_ID",
      "XAI_API_KEY",
      "OPENROUTER_API_KEY",
      "AI_GATEWAY_API_KEY",
      "ZAI_API_KEY",
      "OPENCODE_API_KEY",
      "FIREWORKS_API_KEY",
      "KIMI_API_KEY",
      "MINIMAX_API_KEY",
      "MINIMAX_CN_API_KEY",
      "AWS_PROFILE",
      "AWS_REGION",
      "AWS_ACCESS_KEY_ID",
      "AWS_SECRET_ACCESS_KEY",
      "AWS_SESSION_TOKEN",
      "AWS_BEARER_TOKEN_BEDROCK",
      "AWS_ENDPOINT_URL_BEDROCK_RUNTIME"
    ]
  },
  "security": {
    "allowed_commands": [
      "git",
      "python3",
      "node",
      "cargo",
      "npm",
      "go",
      "make"
    ],
    "signal_mode": "allow_same_sandbox"
  }
}
