{
  "extends": "codex",
  "meta": {
    "name": "lince-codex",
    "description": "LINCE sandbox profile for OpenAI Codex"
  },
  "filesystem": {
    "allow": [
      "$WORKDIR",
      "$HOME/.codex"
    ],
    "read": [
      "$HOME/.local/lib"
    ]
  },
  "security": {
    "signal_mode": "allow_same_sandbox"
  }
}
