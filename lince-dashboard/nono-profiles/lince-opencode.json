{
  "extends": "opencode",
  "meta": {
    "name": "lince-opencode",
    "description": "LINCE sandbox profile for OpenCode"
  },
  "filesystem": {
    "allow": [
      "$WORKDIR",
      "$HOME/.local/share/opencode"
    ],
    "read": [
      "$HOME/.local/lib",
      "$HOME/.config/opencode"
    ]
  },
  "security": {
    "signal_mode": "allow_same_sandbox"
  }
}
