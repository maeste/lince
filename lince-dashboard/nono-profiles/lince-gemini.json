{
  "extends": "default",
  "meta": {
    "name": "lince-gemini",
    "description": "LINCE sandbox profile for Google Gemini CLI"
  },
  "filesystem": {
    "allow": [
      "$WORKDIR",
      "$HOME/.gemini"
    ],
    "read": [
      "$HOME/.local/lib"
    ]
  },
  "security": {
    "signal_mode": "allow_same_sandbox"
  }
}
