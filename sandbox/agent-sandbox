def cmd_init(args) -> None:
    print("Initializing agent-sandbox...\n")

    # Determine use_real_config: --real-config flag or existing config setting
    use_real_config = getattr(args, "real_config", False)
    if not use_real_config:
        try:
            old_stderr = sys.stderr
            sys.stderr = io.StringIO()
            try:
                config_path = find_config()
            finally:
                sys.stderr = old_stderr
            with open(config_path, "rb") as fh:
                existing_config = tomllib.load(fh)
            use_real_config = existing_config.get("claude", {}).get(
                "use_real_config", False
            )
        except SystemExit:
            pass

    # Directory structure
    dirs = [
        SANDBOX_DIR,
        SANDBOX_DIR / "toolchains" / "cargo",
        SANDBOX_DIR / "toolchains" / "npm-cache",
        SANDBOX_DIR / "toolchains" / "go",
        SANDBOX_DIR / "toolchains" / "uv-cache",
        SANDBOX_DIR / "toolchains" / "uv-tools",
        SANDBOX_DIR / "bin",
        SANDBOX_DIR / "logs",
    ]
    if not use_real_config:
        dirs.append(SANDBOX_DIR / "claude-config")
    for d in dirs:
        d.mkdir(parents=True, exist_ok=True)

    if use_real_config:
        # Skip copy — will mount real ~/.claude directly
        print(f"  claude-config using real ~/.claude (use_real_config = true)")
        print(f"  claude.json   using real ~/.claude.json (use_real_config = true)")
    else:
        # Copy Claude config
        src = Path.home() / ".claude"
        dst = SANDBOX_DIR / "claude-config"
        if src.exists():
            if args.force or not any(dst.iterdir()):
                for item in list(dst.iterdir()):
                    if item.is_dir():
                        shutil.rmtree(item)
                    else:
                        item.unlink()
                shutil.copytree(src, dst, dirs_exist_ok=True)
                print(f"  claude-config {src} -> {dst}")
                # Check for secrets in settings.json
                settings = dst / "settings.json"
                if settings.exists() and "SECRET" in settings.read_text().upper():
                    print("\n  WARNING: settings.json may contain secrets "
                          "(MCP server env vars).")
                    print("  Review: " + str(settings))
            else:
                print(f"  claude-config (exists, use --force)")
        else:
            print(f"  claude-config ~/.claude not found, starting empty")

        # Copy Claude runtime state file (~/.claude.json)
        claude_json_src = Path.home() / ".claude.json"
        claude_json_dst = SANDBOX_DIR / "claude.json"
        if claude_json_src.exists():
            if args.force or not claude_json_dst.exists():
                shutil.copy2(claude_json_src, claude_json_dst)
                print(f"  claude.json   {claude_json_src} -> {claude_json_dst}")
            else:
                print(f"  claude.json   (exists, use --force)")
        else:
            print(f"  claude.json   ~/.claude.json not found, skipping")

    # Sanitise gitconfig — use config from file if available, else defaults
    git_src = Path.home() / ".gitconfig"
    if not git_src.exists():
        git_src = Path.home() / ".config" / "git" / "config"
    try:
        old_stderr = sys.stderr
        sys.stderr = io.StringIO()
        try:
            config_path = find_config()
        finally:
            sys.stderr = old_stderr
        with open(config_path, "rb") as fh:
            config = tomllib.load(fh)
    except SystemExit:
        config = {}
    git_conf = config.get("git", {})
    sanitize_gitconfig(
        git_src,
        SANDBOX_DIR / "gitconfig",
        git_conf.get("strip_sections", ["credential", 'url ".*"']),
        git_conf.get("overrides", {"push.default": "nothing"}),
    )
    print(f"  gitconfig     {SANDBOX_DIR / 'gitconfig'}")

    # Copy agents-defaults.toml into SANDBOX_DIR so it is found at search path #2
    agents_defaults_src = Path(__file__).resolve().parent / "agents-defaults.toml"
    agents_defaults_dst = SANDBOX_DIR / "agents-defaults.toml"
    if agents_defaults_src.is_file():
        shutil.copy2(agents_defaults_src, agents_defaults_dst)
        print(f"  agents-defaults {agents_defaults_dst}")

    # Git-push wrapper
    ensure_git_wrapper()
    print(f"  git wrapper   {SANDBOX_DIR / 'bin' / 'git'}")

    # Auto-detected PATH dirs
    home_dirs = detect_home_path_dirs()
    if home_dirs:
        print(f"\n  Auto-detected PATH dirs under $HOME ({len(home_dirs)}):")
        for d in home_dirs:
            print(f"    ro  {d}")

    # Create default config.toml if none exists
    config_created = False
    try:
        old_stderr = sys.stderr
        sys.stderr = io.StringIO()
        try:
            cp = find_config()
        finally:
            sys.stderr = old_stderr
        print(f"\nUsing config:\n  {cp}\n")
    except SystemExit:
        default_cfg = SANDBOX_DIR / "config.toml"
        default_cfg.write_text(_DEFAULT_CONFIG)
        print(f"\n  config.toml   created {default_cfg}")
        config_created = True

    if config_created:
        print(f"\nEdit {SANDBOX_DIR / 'config.toml'} to configure profiles and API keys.\n")

    print("Run Claude in sandbox:\n  agent-sandbox run\n")


def cmd_run(args, agent_extra: list[str]) -> None:
    check_bwrap()
    config, config_path = load_config()

    project_dir = Path(args.project).resolve()
    if not project_dir.is_dir():
        print(f"Error: not a directory: {project_dir}", file=sys.stderr)
        sys.exit(1)

    # Resolve agent configuration
    agent_name = args.agent
    agent_cfg = resolve_agent_config(config, agent_name)

    # Ensure git wrapper exists
    if config.get("security", {}).get("block_git_push", True):
        ensure_git_wrapper()

    # Logging
    log_conf = config.get("logging", {})
    do_log = args.log if args.log is not None else log_conf.get("enabled", False)
    log_file = None
    if do_log:
        log_dir = expand(log_conf.get("dir", "~/.agent-sandbox/logs"))
        log_dir.mkdir(parents=True, exist_ok=True)
        ts = datetime.now().strftime("%Y-%m-%d_%H%M%S")
        log_file = log_dir / f"{ts}_{project_dir.name}.log"

    # Resolve profile: explicit -P flag > default_profile from config
    profile = args.profile
    from_default = False
    if profile is None:
        profile = config.get("sandbox", {}).get("default_profile", "") or None
        from_default = True
    prof_desc = None
    if profile:
        profiles = resolve_profiles(config, agent_name)
        if profile not in profiles:
            if from_default:
                # default_profile doesn't exist for this agent type — silently skip
                profile = None
            else:
                # Explicit -P flag: hard error
                avail = ", ".join(sorted(profiles)) if profiles else "(none defined)"
                print(f"Error: unknown profile '{profile}'.", file=sys.stderr)
                print(f"Available profiles: {avail}", file=sys.stderr)
                sys.exit(1)
        prof_desc = profiles[profile].get("description", "")

    # Build command
    cmd = build_bwrap_cmd(config, project_dir, agent_extra, log_file,
                          profile=profile, safe_mode=args.safe,
                          extra_rw_cli=args.rw, extra_ro_cli=args.ro,
                          agent_config=agent_cfg, agent_id=args.id,
                          agent_name=agent_name)

    if args.dry_run:
        print("# bwrap command that would be executed:\n")
        print(f"# config: {config_path}")
        print(f"# agent: {agent_name} ({agent_cfg['command']})")
        if profile:
            print(f"# profile: {profile}")
        _pretty_print_cmd(cmd)
        return

    # Print banner
    sec = config.get("security", {})
    use_real = config.get("claude", {}).get("use_real_config", False)
    print("agent-sandbox")
    print(f"  config      {config_path}")
    print(f"  agent       {agent_name} ({agent_cfg['command']})")
    if profile:
        desc = f" ({prof_desc})" if prof_desc else ""
        print(f"  profile     {profile}{desc}")
    if use_real:
        print(f"  agent-cfg   real ~/.claude (use_real_config)")
    else:
        cc_dir = expand(config.get("claude", {}).get("config_dir",
                        "~/.agent-sandbox/claude-config"))
        print(f"  agent-cfg   {cc_dir} (isolated copy)")
    print(f"  project     {project_dir}")
    print(f"  filesystem  read-only root, writable project dir")
    print(f"  network     enabled")
    print(f"  pid isolat. {'on' if sec.get('unshare_pid', True) else 'off'}")
    print(f"  git push    {'blocked' if sec.get('block_git_push', True) else 'allowed'}")
    print(f"  env vars    clearenv + whitelist")
    if agent_cfg.get("bwrap_conflict"):
        print(f"  bwrap fix   inner sandbox disabled via {agent_cfg.get('disable_inner_sandbox_args', [])}")
    print(f"  permissions {'ask (safe mode)' if args.safe else 'per agent defaults'}")
    if args.rw:
        print(f"  extra rw    {', '.join(args.rw)}")
    if args.ro:
        print(f"  extra ro    {', '.join(args.ro)}")
    if log_file:
        print(f"  logging     {log_file}")
    print()

    try:
        result = subprocess.run(cmd, cwd=str(project_dir))
        sys.exit(result.returncode)
    except KeyboardInterrupt:
        print("\nSandbox terminated.")
    except FileNotFoundError as exc:
        print(f"Error: {exc}", file=sys.stderr)
        sys.exit(1)


