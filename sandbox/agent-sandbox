def main() -> None:
    _check_migration()
    parser = argparse.ArgumentParser(
        prog="agent-sandbox",
        description="Secure bubblewrap sandbox for AI coding agents.",
    )
    sub = parser.add_subparsers(dest="command")

    # init
    p_init = sub.add_parser("init", help="Initialise sandbox environment")
    p_init.add_argument("-f", "--force", action="store_true",
                        help="Overwrite existing config and files")
    p_init.add_argument("--real-config", action="store_true",
                        help="Use real ~/.claude directly (set use_real_config=true)")

    # run
    p_run = sub.add_parser("run", help="Run an agent inside the sandbox")
    p_run.add_argument("-p", "--project", default=".",
                       help="Project directory (default: cwd)")
    p_run.add_argument("-a", "--agent", default="claude",
                       help="Agent to run (default: claude). "
                            "Looks up [agents.<name>] in config.")
    p_run.add_argument("-P", "--profile", default=None,
                       help="Provider profile name (defined in config.toml)")
    p_run.add_argument("--log", action="store_true", default=None,
                       help="Enable session transcript logging")
    p_run.add_argument("--no-log", action="store_false", dest="log",
                       help="Disable session transcript logging")
    p_run.add_argument("--safe", action="store_true",
                       help="Disable --dangerously-skip-permissions for this run")
    p_run.add_argument("--dry-run", action="store_true",
                       help="Print bwrap command without executing")
    p_run.add_argument("--rw", action="append", default=[],
                       metavar="DIR", help="Extra read-write directory for this run (repeatable)")
    p_run.add_argument("--ro", action="append", default=[],
                       metavar="DIR", help="Extra read-only directory for this run (repeatable)")
    p_run.add_argument("--id", default=None, metavar="ID",
                       help="Agent ID (sets LINCE_AGENT_ID env var inside sandbox)")
    p_run.add_argument("--sandbox-level", dest="sandbox_level", default=None,
                       metavar="NAME",
                       help="Sandbox isolation level: paranoid|normal|permissive "
                            "(or any custom name). Loads the matching policy fragment "
                            "from sandbox/profiles/<NAME>.toml (built-in) or "
                            "~/.agent-sandbox/profiles/<NAME>.toml (user-supplied) and "
                            "merges it into the config before running.")

    # diff
    sub.add_parser("diff",
                   help="Show differences between sandbox and real config")

    # merge
    sub.add_parser("merge",
                   help="Interactive merge: sandbox config -> real ~/.claude")

    # status
    sub.add_parser("status", help="Show sandbox status")

    # proxy-status
    sub.add_parser("proxy-status",
                   help="Show credential proxy status")

    # --- Snapshot subcommands ---

    # snapshot
    p_snap = sub.add_parser(
        "snapshot", help="Create filesystem snapshots",
    )
    p_snap.add_argument(
        "-a", "--agent", default="claude",
        help="Agent name (default: claude)",
    )
    p_snap.add_argument(
        "-p", "--project", default=".",
        help="Project directory (default: cwd)",
    )
    p_snap.add_argument(
        "--config-only", action="store_true",
        help="Snapshot only the agent config dir",
    )
    p_snap.add_argument(
        "--project-only", action="store_true",
        help="Snapshot only the project dir",
    )

    # snapshot-list
    p_snl = sub.add_parser(
        "snapshot-list",
        help="List available snapshots",
    )
    p_snl.add_argument(
        "-a", "--agent", default="claude",
        help="Agent name (default: claude)",
    )
    p_snl.add_argument(
        "-p", "--project", default=".",
        help="Project directory (default: cwd)",
    )
    p_snl_filter = p_snl.add_mutually_exclusive_group()
    p_snl_filter.add_argument(
        "--config-only", dest="config", action="store_true",
        help="Show only config snapshots",
    )
    p_snl_filter.add_argument(
        "--project-only", dest="project_only",
        action="store_true",
        help="Show only project snapshots",
    )

    # snapshot-diff
    p_snd = sub.add_parser(
        "snapshot-diff",
        help="Compare snapshot(s) vs current state",
    )
    p_snd.add_argument(
        "timestamps", nargs="*",
        help="Timestamp(s): 0=latest vs current, "
             "1=that vs current, 2=compare two",
    )
    p_snd.add_argument(
        "-a", "--agent", default="claude",
        help="Agent name (default: claude)",
    )
    p_snd.add_argument(
        "-p", "--project", default=".",
        help="Project directory (default: cwd)",
    )
    p_snd_filter = p_snd.add_mutually_exclusive_group()
    p_snd_filter.add_argument(
        "--config-only", dest="config", action="store_true",
        help="Diff only config snapshots",
    )
    p_snd_filter.add_argument(
        "--project-only", dest="project_flag",
        action="store_true",
        help="Diff only project snapshots",
    )

    # snapshot-restore
    p_snr = sub.add_parser(
        "snapshot-restore",
        help="Interactive restore from snapshot",
    )
    p_snr.add_argument(
        "timestamp", nargs="?", default=None,
        help="Snapshot timestamp (default: latest)",
    )
    p_snr.add_argument(
        "-a", "--agent", default="claude",
        help="Agent name (default: claude)",
    )
    p_snr.add_argument(
        "-p", "--project", default=".",
        help="Project directory (default: cwd)",
    )
    p_snr_filter = p_snr.add_mutually_exclusive_group()
    p_snr_filter.add_argument(
        "--config-only", dest="config", action="store_true",
        help="Restore only config",
    )
    p_snr_filter.add_argument(
        "--project-only", dest="project_flag",
        action="store_true",
        help="Restore only project",
    )

    # snapshot-prune
    p_snp = sub.add_parser(
        "snapshot-prune",
        help="Remove old snapshots",
    )
    p_snp.add_argument(
        "-a", "--agent", default="claude",
        help="Agent name (default: claude)",
    )
    p_snp.add_argument(
        "-p", "--project", default=".",
        help="Project directory (default: cwd)",
    )
    p_snp.add_argument(
        "--config-only", dest="config", action="store_true",
        help="Prune only config snapshots",
    )
    p_snp.add_argument(
        "--project-only", dest="project_flag",
        action="store_true",
        help="Prune only project snapshots",
    )
    p_snp.add_argument(
        "--all", dest="all_types", action="store_true",
        help="Prune both project and config snapshots",
    )

    # learn
    p_learn = sub.add_parser(
        "learn",
        help="Run agent under strace to learn its access patterns",
    )
    p_learn.add_argument(
        "-a", "--agent", default="claude",
        help="Agent to learn (default: claude)",
    )
    p_learn.add_argument(
        "-P", "--profile", default=None,
        help="Provider profile name (defined in config.toml)",
    )
    p_learn.add_argument(
        "--duration", type=int, default=None, metavar="SECONDS",
        help="Kill the agent after N seconds",
    )
    p_learn.add_argument(
        "--compare", action="store_true",
        help="Compare observed needs vs current config",
    )
    p_learn.add_argument(
        "--apply", action="store_true",
        help="Auto-merge suggestions into config.toml",
    )
    p_learn.add_argument(
        "--output", default=None, metavar="FILE",
        help="Save TOML suggestions to FILE (default: temp file)",
    )

    # nono-sync
    p_nono = sub.add_parser(
        "nono-sync",
        help="Generate nono JSON profiles from lince agent configuration",
    )
    p_nono.add_argument(
        "--dry-run", action="store_true",
        help="Print generated JSON without writing files",
    )
    p_nono.add_argument(
        "--agent", default=None,
        help="Sync a specific agent only (default: all agents)",
    )
    p_nono.add_argument(
        "-P", "--profile", default=None,
        help="Provider profile name for env var mapping",
    )

    # ---- Split argv on '--' so extra args go to the agent -------------------
    argv = sys.argv[1:]
    if "--" in argv:
        sep = argv.index("--")
        our_argv = argv[:sep]
        agent_extra = argv[sep + 1:]
    else:
        our_argv = argv
        agent_extra = []

    args, unknown = parser.parse_known_args(our_argv)

    if args.command is None:
        parser.print_help()
        sys.exit(0)

    if args.command == "run":
        # Unknown options pass through to the agent CLI
        agent_extra = unknown + agent_extra
    elif unknown:
        parser.error(f"unrecognized arguments: {' '.join(unknown)}")

    dispatch = {
        "init": lambda: cmd_init(args),
        "run": lambda: cmd_run(args, agent_extra),
        "diff": lambda: cmd_diff(args),
        "merge": lambda: cmd_merge(args),
        "status": lambda: cmd_status(args),
        "proxy-status": lambda: cmd_proxy_status(args),
        "snapshot": lambda: cmd_snapshot(args),
        "snapshot-list": lambda: cmd_snapshot_list(args),
        "snapshot-diff": lambda: cmd_snapshot_diff(args),
        "snapshot-restore": lambda: cmd_snapshot_restore(args),
        "snapshot-prune": lambda: cmd_snapshot_prune(args),
        "learn": lambda: cmd_learn(args),
        "nono-sync": lambda: cmd_nono_sync(args),
    }
    dispatch[args.command]()


if __name__ == "__main__":
    main()
