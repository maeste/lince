# Regex patterns for strace output parsing
_RE_OPENAT = re.compile(
    r'openat2?\(.*?,\s*"([^"]+)",\s*([^)]+)\)\s*=\s*(-?\d+)'
)
_RE_CONNECT_V4 = re.compile(
    r'connect\(\d+,\s*\{sa_family=AF_INET,\s*sin_port=htons\((\d+)\),'
    r'\s*sin_addr=inet_addr\("([^"]+)"\)'
)
_RE_CONNECT_V6 = re.compile(
    r'connect\(\d+,\s*\{sa_family=AF_INET6,\s*sin6_port=htons\((\d+)\),'
    r'\s*sin6_addr=inet6_addr\("([^"]+)"\)'
)
_RE_EXECVE = re.compile(
    r'execve\("([^"]+)",\s*\[([^\]]*)\]'
)

# Paths that are noise and should be ignored
_NOISE_PREFIXES = (
    "/proc/", "/sys/", "/dev/",
)
_NOISE_EXACT = frozenset({
    "/etc/ld.so.cache", "/etc/ld.so.preload",
})


class StraceParser:
    """Parse strace output into categorized filesystem and network access lists."""

    def __init__(self, trace_file: str, home_dir: str | None = None,
                 project_dir: str | None = None):
        self.trace_file = trace_file
        self.reads: set[str] = set()
        self.writes: set[str] = set()
        self.network: list[tuple[str, int, str]] = []  # (host_or_ip, port, proto)
        self.executables: set[str] = set()
        self.home_dir = home_dir or str(Path.home())
        self.project_dir = project_dir or os.getcwd()
        self._dns_cache: dict[str, str] = {}

    def parse(self) -> None:
        """Parse the strace trace file line by line."""
        with open(self.trace_file, "r", errors="replace") as fh:
            for line in fh:
                line = line.strip()
                # Strip leading PID tag from multi-process traces
                # e.g. "[pid 12345] openat(...) = 3"
                if line.startswith("[pid"):
                    bracket_end = line.find("]")
                    if bracket_end != -1:
                        line = line[bracket_end + 1:].strip()

                self._parse_openat(line)
                self._parse_connect(line)
                self._parse_execve(line)

    def _parse_openat(self, line: str) -> None:
        """Parse openat/openat2 calls to extract file access."""
        m = _RE_OPENAT.search(line)
        if not m:
            return
        path = m.group(1)
        flags = m.group(2)
        retval = int(m.group(3))

        # Skip failed calls (fd == -1)
        if retval < 0:
            return

        path = self._normalize_path(path)
        if not path or self._is_noise(path):
            return

        if any(f in flags for f in ("O_WRONLY", "O_RDWR", "O_CREAT", "O_TRUNC")):
            self.writes.add(path)
        else:
            self.reads.add(path)

    def _parse_connect(self, line: str) -> None:
        """Parse connect() calls to extract network connections."""
        for pattern, proto in [
            (_RE_CONNECT_V4, "tcp4"), (_RE_CONNECT_V6, "tcp6"),
        ]:
            m = pattern.search(line)
            if m:
                port = int(m.group(1))
                ip = m.group(2)
                if port == 0 or ip in ("0.0.0.0", "127.0.0.1", "::1", "::"):
                    return
                hostname = self._resolve_ip(ip)
                self.network.append((hostname, port, proto))
                return

    def _parse_execve(self, line: str) -> None:
        """Parse execve() calls to extract executed binaries."""
        m = _RE_EXECVE.search(line)
        if m:
            exe_path = m.group(1)
            if exe_path and not exe_path.startswith("/proc/"):
                self.executables.add(exe_path)

    def _normalize_path(self, path: str) -> str | None:
        """Resolve symlinks, collapse /proc/self/, normalize the path."""
        if not path or not path.startswith("/"):
            return None
        # /proc/self/fd/... are fd references, not real paths
        if path.startswith("/proc/self/fd/"):
            return None
        if path.startswith("/proc/thread-self/"):
            return None
        if path.startswith("/proc/self/"):
            return None
        try:
            resolved = str(Path(path).resolve())
            return resolved
        except (OSError, ValueError):
            return path

    def _is_noise(self, path: str) -> bool:
        """Check if a path is uninteresting noise."""
        if path in _NOISE_EXACT:
            return True
        for prefix in _NOISE_PREFIXES:
            if path.startswith(prefix):
                return True
        return False

    def _resolve_ip(self, ip: str) -> str:
        """Reverse-resolve an IP to hostname, with caching."""
        if ip in self._dns_cache:
            return self._dns_cache[ip]
        try:
            hostname = socket.gethostbyaddr(ip)[0]
        except (socket.herror, socket.gaierror, OSError):
            hostname = ip
        self._dns_cache[ip] = hostname
        return hostname

    def categorize(self) -> dict[str, dict[str, set[str]]]:
        """Group accessed paths by category.

        Returns a dict of category -> {reads: set, writes: set}.
        Categories: project, home_config, system, toolchain, temp, unexpected.
        """
        categories: dict[str, dict[str, set[str]]] = {
            "project": {"reads": set(), "writes": set()},
            "home_config": {"reads": set(), "writes": set()},
            "system": {"reads": set(), "writes": set()},
            "toolchain": {"reads": set(), "writes": set()},
            "temp": {"reads": set(), "writes": set()},
            "unexpected": {"reads": set(), "writes": set()},
        }

        home = self.home_dir
        project = self.project_dir

        toolchain_prefixes = tuple(
            os.path.join(home, d) for d in (
                ".cargo", ".npm", ".cache", ".uv-cache", ".uv-tools",
                ".go", ".rustup", ".nvm", ".pyenv", ".local/share/uv",
            )
        )
        config_prefixes = tuple(
            os.path.join(home, d) for d in (
                ".claude", ".config", ".claude.json", ".gitconfig",
                ".codex", ".gemini", ".aider", ".agent-sandbox",
                ".local/share", ".ssh",
            )
        )
        system_prefixes = (
            "/usr/", "/etc/", "/lib/", "/lib64/",
            "/bin/", "/sbin/", "/opt/", "/snap/",
        )
        temp_prefixes = ("/tmp/", "/var/tmp/")

        for access_type, path_set in [
            ("reads", self.reads), ("writes", self.writes),
        ]:
            for path in path_set:
                cat = _classify_path(
                    path, project, home, toolchain_prefixes,
                    config_prefixes, system_prefixes, temp_prefixes,
                )
                categories[cat][access_type].add(path)

        return categories


def _classify_path(
    path: str, project: str, home: str,
    toolchain_prefixes: tuple[str, ...],
    config_prefixes: tuple[str, ...],
    system_prefixes: tuple[str, ...],
    temp_prefixes: tuple[str, ...],
) -> str:
    """Classify a single path into a category name."""
    if path.startswith(project + "/") or path == project:
        return "project"
    for prefix in temp_prefixes:
        if path.startswith(prefix):
            return "temp"
    for prefix in toolchain_prefixes:
        if path.startswith(prefix + "/") or path == prefix:
            return "toolchain"
    for prefix in config_prefixes:
        if path.startswith(prefix + "/") or path == prefix:
            return "home_config"
    for prefix in system_prefixes:
        if path.startswith(prefix):
            return "system"
    if path.startswith(home + "/") or path == home:
        return "unexpected"
    return "system"


def _group_paths_by_directory(paths: set[str]) -> dict[str, int]:
    """Group file paths by parent directory.

    Returns dict of directory -> file count, collapsing children that share
    a common ancestor already present in the result.
    """
    dir_counts: dict[str, int] = {}
    for p in paths:
        parent = str(Path(p).parent)
        dir_counts[parent] = dir_counts.get(parent, 0) + 1

    # Collapse: if a child dir's ancestor is already tracked, merge into it
    collapsed: dict[str, int] = {}
    for d, count in sorted(dir_counts.items()):
        merged = False
        for ancestor in collapsed:
            if d.startswith(ancestor + "/") or d == ancestor:
                collapsed[ancestor] += count
                merged = True
                break
        if not merged:
            collapsed[d] = count

    return collapsed


def _path_to_tilde(path: str, home: str) -> str:
    """Replace home directory prefix with ~ for display."""
    if path.startswith(home + "/"):
        return "~" + path[len(home):]
    if path == home:
        return "~"
    return path


def _infer_path_comment(path: str) -> str:
    """Generate a short comment describing what a directory is for."""
    name = Path(path).name
    comments: dict[str, str] = {
        ".cargo": "Rust cargo cache",
        ".npm": "npm package cache",
        ".cache": "general cache directory",
        ".uv-cache": "uv package cache",
        ".uv-tools": "uv installed tools",
        ".go": "Go module cache",
        ".rustup": "Rust toolchain manager",
        ".nvm": "Node version manager",
        ".pyenv": "Python version manager",
        ".config": "application configuration",
        ".claude": "Claude Code configuration",
        ".codex": "Codex configuration",
        ".gemini": "Gemini configuration",
        ".aider": "Aider configuration",
        ".agent-sandbox": "agent-sandbox configuration",
        ".local": "local data and binaries",
        ".ssh": "SSH keys and config",
        ".gitconfig": "Git configuration",
        "ruff": "ruff linter configuration",
        "uv": "uv package manager",
    }
    return comments.get(name, "")


def generate_config_suggestions(
    categories: dict[str, dict[str, set[str]]],
    config: dict,
    agent_name: str,
    home_dir: str,
) -> tuple[list[str], list[str], str]:
    """Compare observed access with current config.

    Returns:
        additions: human-readable config additions needed
        removals: human-readable config entries that seem unnecessary
        toml_fragment: TOML string with suggested configuration
    """
    sandbox_cfg = config.get("sandbox", {})
    env_cfg = config.get("env", {})
    agent_cfg = resolve_agent_config(config, agent_name)

    current_extra_rw = {str(expand(d)) for d in sandbox_cfg.get("extra_rw", [])}
    current_ro_dirs = {str(expand(d)) for d in sandbox_cfg.get("ro_dirs", [])}
    current_home_ro = {
        str(Path(home_dir) / d) for d in sandbox_cfg.get("home_ro_dirs", [])
    }
    current_agent_ro = {
        str(Path(home_dir) / d) for d in agent_cfg.get("home_ro_dirs", [])
    }
    current_agent_rw = {
        str(Path(home_dir) / d) for d in agent_cfg.get("home_rw_dirs", [])
    }
    current_passthrough = set(env_cfg.get("passthrough", []))

    all_current_rw = current_extra_rw | current_agent_rw
    all_current_ro = current_ro_dirs | current_home_ro | current_agent_ro

    additions: list[str] = []
    removals: list[str] = []
    suggest_rw: list[str] = []
    suggest_ro: list[str] = []

    # Check writes outside project — these need writable mounts
    for cat_name in ("home_config", "toolchain", "unexpected"):
        write_paths = categories.get(cat_name, {}).get("writes", set())
        if not write_paths:
            continue
        grouped = _group_paths_by_directory(write_paths)
        for directory, count in sorted(grouped.items()):
            already_covered = any(
                directory.startswith(rw + "/") or directory == rw
                for rw in all_current_rw
            )
            if not already_covered:
                display = _path_to_tilde(directory, home_dir)
                comment = _infer_path_comment(directory)
                reason = (
                    f"({comment})" if comment
                    else f"({count} file(s) written)"
                )
                additions.append(
                    f"Add writable:  {display:<30s} {reason}"
                )
                suggest_rw.append(directory)

    # Check reads of home dirs not currently exposed
    for cat_name in ("home_config", "toolchain"):
        read_paths = categories.get(cat_name, {}).get("reads", set())
        if not read_paths:
            continue
        grouped = _group_paths_by_directory(read_paths)
        for directory, count in sorted(grouped.items()):
            already_covered = any(
                directory.startswith(kd + "/") or directory == kd
                for kd in (all_current_rw | all_current_ro)
            )
            # Skip if already suggested as writable
            if not already_covered:
                already_covered = any(
                    directory.startswith(sw + "/") or directory == sw
                    for sw in suggest_rw
                )
            if not already_covered:
                display = _path_to_tilde(directory, home_dir)
                comment = _infer_path_comment(directory)
                reason = (
                    f"({comment})" if comment
                    else f"({count} file(s) read)"
                )
                additions.append(
                    f"Add read-only: {display:<30s} {reason}"
                )
                suggest_ro.append(directory)

    # Build TOML fragment
    now = datetime.now().strftime("%Y-%m-%dT%H:%M:%S")
    toml_lines: list[str] = [
        f"# Suggested config changes based on learn session",
        f"# Generated by: agent-sandbox learn {agent_name} ({now})",
        f"# Review and merge into your config.toml",
        "",
    ]

    if suggest_rw:
        toml_lines.append("[sandbox]")
        toml_lines.append(
            "# These directories were written to by the agent:"
        )
        toml_lines.append("extra_rw = [")
        for d in sorted(suggest_rw):
            display = _path_to_tilde(d, home_dir)
            comment = _infer_path_comment(d)
            if comment:
                toml_lines.append(f'    "{display}",    # {comment}')
            else:
                toml_lines.append(f'    "{display}",')
        toml_lines.append("]")
        toml_lines.append("")

    if suggest_ro:
        if not suggest_rw:
            toml_lines.append("[sandbox]")
        toml_lines.append(
            "# These directories were read by the agent:"
        )
        ro_home_entries: list[str] = []
        for d in sorted(suggest_ro):
            if d.startswith(home_dir + "/"):
                rel = d[len(home_dir) + 1:]
                comment = _infer_path_comment(d)
                if comment:
                    ro_home_entries.append(
                        f'    "{rel}",    # {comment}'
                    )
                else:
                    ro_home_entries.append(f'    "{rel}",')
        if ro_home_entries:
            toml_lines.append("home_ro_dirs = [")
            toml_lines.extend(ro_home_entries)
            toml_lines.append("]")
            toml_lines.append("")

    if current_passthrough:
        toml_lines.append("[env]")
        toml_lines.append(
            "# Current passthrough env vars (review for necessity):"
        )
        toml_lines.append("passthrough = [")
        for var in sorted(current_passthrough):
            toml_lines.append(f'    "{var}",')
        toml_lines.append("]")
        toml_lines.append("")

    return additions, removals, "\n".join(toml_lines)


def _aggregate_network(
    network: list[tuple[str, int, str]],
) -> list[tuple[str, int, int]]:
    """Aggregate network connections by (host, port), return sorted list."""
    counts: dict[tuple[str, int], int] = {}
    for host, port, _proto in network:
        key = (host, port)
        counts[key] = counts.get(key, 0) + 1
    return [
        (host, port, count)
        for (host, port), count in sorted(counts.items())
    ]


def print_learn_report(
    categories: dict[str, dict[str, set[str]]],
    network: list[tuple[str, int, str]],
    executables: set[str],
    additions: list[str],
    removals: list[str],
    agent_name: str,
    duration_secs: float,
    trace_file: str,
    toml_output: str | None = None,
) -> None:
    """Print a human-readable learn mode report to stdout."""
    bar = "\u2550" * 51
    thin = "\u2500" * 49

    print(f"\n{bar}")
    print(f" Learn Mode Report \u2014 agent: {agent_name}")
    dur = f"{duration_secs:.0f}s"
    print(f" Duration: {dur} | Trace file: {trace_file}")
    print(f"{bar}")

    # Filesystem access summary
    print(f"\n \U0001f4c2 Filesystem Access")
    print(f" {thin}")
    cat_labels = [
        ("project", "Project files"),
        ("home_config", "Home config"),
        ("system", "System paths"),
        ("toolchain", "Toolchain caches"),
        ("temp", "Temp files"),
        ("unexpected", "Unexpected"),
    ]
    home_dir = str(Path.home())
    for cat_key, cat_label in cat_labels:
        cat = categories.get(
            cat_key, {"reads": set(), "writes": set()}
        )
        nr = len(cat["reads"])
        nw = len(cat["writes"])
        all_paths = cat["reads"] | cat["writes"]
        if all_paths:
            dirs: set[str] = set()
            for p in all_paths:
                parts = Path(p).parts
                depth = min(len(parts), 4)
                dirs.add(str(Path(*parts[:depth])))
            top_dirs = sorted(dirs)[:3]
            display_dirs = [
                _path_to_tilde(d, home_dir) for d in top_dirs
            ]
            ellipsis = "..." if len(dirs) > 3 else ""
            suffix = f"  ({', '.join(display_dirs)}{ellipsis})"
        else:
            suffix = ""
        print(
            f" {cat_label:<20s} {nr:>4d} reads, "
            f"{nw:>3d} writes{suffix}"
        )

    # Network connections
    print(f"\n \U0001f310 Network Connections")
    print(f" {thin}")
    if network:
        aggregated = _aggregate_network(network)
        for host, port, count in aggregated:
            s = "s" if count > 1 else ""
            conn_str = f"({count} connection{s})"
            print(f" {host}:{port:<6d}       {conn_str}")
    else:
        print(" (none detected)")

    # Executables
    print(f"\n \u2699\ufe0f  Executables")
    print(f" {thin}")
    if executables:
        exe_list = sorted(executables)
        line = " "
        for i, exe in enumerate(exe_list):
            if i > 0:
                line += ", "
            if len(line) + len(exe) > 100:
                print(line)
                line = " "
            line += exe
        if line.strip():
            print(line)
    else:
        print(" (none detected)")

    # Suggested config changes
    print(f"\n \U0001f4cb Suggested Config Changes")
    print(f" {thin}")
    if additions or removals:
        for addition in additions:
            print(f" \u271a {addition}")
        for removal in removals:
            print(f" \u2296 {removal}")
    else:
        print(
            " (no changes suggested \u2014 "
            "current config covers observed access)"
        )

    if toml_output:
        print(f"\n \U0001f4be TOML fragment saved to: {toml_output}")
        print(f"    Review and merge into your config.toml")

    print()


def build_learn_bwrap_cmd(
    config: dict,
    project_dir: Path,
    agent_config: dict,
    agent_name: str = "claude",
    profile: str | None = None,
) -> list[str]:
    """Build a permissive bwrap command for learn mode.

    Similar to build_bwrap_cmd but with the home directory writable
    so we can observe what the agent tries to access.
    """
    home = str(Path.home())
    sandbox = config.get("sandbox", {})
    env_conf = config.get("env", {})
    sec = config.get("security", {})
    agent_cfg = agent_config

    # Resolve profile
    prof: dict = {}
    if profile:
        profiles = resolve_profiles(config, agent_name)
        if profile in profiles:
            prof = profiles[profile]

    cmd: list[str] = ["bwrap"]

    # 1. Whole FS read-only
    cmd += ["--ro-bind", "/", "/"]

    # 2. Fresh tmpfs for temporary locations
    cmd += ["--tmpfs", "/tmp"]
    uid = os.getuid()
    runtime_dir = os.environ.get(
        "XDG_RUNTIME_DIR", f"/run/user/{uid}"
    )
    cmd += ["--tmpfs", f"/run/user/{uid}"]

    # Re-expose Zellij socket dir
    zellij_socket_dir = os.path.join(runtime_dir, "zellij")
    if os.path.isdir(zellij_socket_dir):
        dest = f"/run/user/{uid}/zellij"
        cmd += ["--bind", zellij_socket_dir, dest]

    # Lince status dir
    lince_status_dir = "/tmp/lince-dashboard"
    os.makedirs(lince_status_dir, exist_ok=True)
    cmd += ["--bind", lince_status_dir, lince_status_dir]

    # Wayland socket for clipboard
    wayland_display = os.environ.get("WAYLAND_DISPLAY", "wayland-0")
    wayland_socket = f"{runtime_dir}/{wayland_display}"
    if os.path.exists(wayland_socket):
        cmd += [
            "--ro-bind", wayland_socket,
            f"/run/user/{uid}/{wayland_display}",
        ]
    cmd += ["--tmpfs", "/var/tmp"]
    cmd += ["--dev", "/dev"]
    cmd += ["--proc", "/proc"]

    # 3. HOME writable — key difference from normal run
    cmd += ["--bind", home, home]

    # 4. Project directory (read-write)
    project = str(project_dir.resolve())
    cmd += ["--bind", project, project]

    # 5. Security options (keep PID isolation)
    if sec.get("unshare_pid", True):
        cmd += ["--unshare-pid"]
    if sec.get("new_session", False):
        cmd += ["--new-session"]
    cmd += ["--die-with-parent"]

    # 6. Environment: clearenv + explicit whitelist
    cmd += ["--clearenv"]
    cmd += ["--setenv", "HOME", home]
    cmd += ["--setenv", "USER", os.environ.get("USER", "user")]
    cmd += ["--setenv", "SHELL", "/bin/bash"]

    # Build PATH
    path_parts: list[str] = []
    if sec.get("block_git_push", True):
        path_parts.append(str(SANDBOX_DIR / "bin"))
    path_parts += ["/usr/local/bin", "/usr/bin", "/bin"]
    if sandbox.get("auto_expose_path", True):
        home_top_dirs = detect_home_path_dirs()
        mounted_tops = set(home_top_dirs)
        for p in home_top_dirs:
            path_parts.append(str(p))
            for sub in ("bin",):
                sp = p / sub
                if sp.is_dir() and str(sp) not in path_parts:
                    path_parts.append(str(sp))
        home_p = Path.home()
        for entry in detect_home_path_entries():
            entry_str = str(entry)
            if entry_str in path_parts:
                continue
            try:
                rel = entry.relative_to(home_p)
            except ValueError:
                continue
            top = home_p / rel.parts[0]
            if top in mounted_tops:
                path_parts.append(entry_str)
    cmd += ["--setenv", "PATH", ":".join(dict.fromkeys(path_parts))]

    # Toolchain env vars
    cmd += ["--setenv", "CARGO_HOME", f"{home}/.cargo"]
    cmd += ["--setenv", "NPM_CONFIG_CACHE", f"{home}/.npm"]
    cmd += ["--setenv", "GOPATH", f"{home}/.go"]
    cmd += ["--setenv", "GOMODCACHE", f"{home}/.go/pkg/mod"]
    cmd += ["--setenv", "UV_CACHE_DIR", f"{home}/.uv-cache"]
    cmd += ["--setenv", "UV_TOOL_DIR", f"{home}/.uv-tools"]

    # Wayland env vars
    for wl_var in ("WAYLAND_DISPLAY", "XDG_RUNTIME_DIR"):
        val = os.environ.get(wl_var)
        if val is not None:
            cmd += ["--setenv", wl_var, val]

    # User-whitelisted env vars
    for var in env_conf.get("passthrough", []):
        val = os.environ.get(var)
        if val is not None:
            cmd += ["--setenv", var, val]

    # Extra env vars (from base config)
    for var, val in env_conf.get("extra", {}).items():
        cmd += ["--setenv", var, _expand_env_value(val)]

    # Profile env vars
    for var, val in prof.get("env", {}).items():
        cmd += ["--setenv", var, _expand_env_value(val)]

    # Agent-specific env vars
    for var, val in agent_cfg.get("env", {}).items():
        cmd += ["--setenv", var, _expand_env_value(val)]

    # 7. Separator and command
    cmd += ["--"]

    args_source = list(
        prof.get("default_args", agent_cfg.get("default_args", []))
    )
    if agent_cfg.get("bwrap_conflict", False):
        disable_args = agent_cfg.get("disable_inner_sandbox_args", [])
        for da in disable_args:
            if da not in args_source:
                args_source.append(da)
    cmd += [agent_cfg["command"]] + args_source

    return cmd


def _deep_merge_toml(base: dict, override: dict) -> dict:
    """Deep-merge *override* into *base*, returning a new dict.

    - dict values are merged recursively
    - list values are extended (with dedup, preserving order)
    - scalar values from *override* replace *base*
    """
    result = dict(base)
    for key, value in override.items():
        if key in result:
            existing = result[key]
            if isinstance(existing, dict) and isinstance(value, dict):
                result[key] = _deep_merge_toml(existing, value)
            elif isinstance(existing, list) and isinstance(value, list):
                seen: set = set()
                merged: list = []
                for lst in (existing, value):
                    for item in lst:
                        if item not in seen:
                            seen.add(item)
                            merged.append(item)
                result[key] = merged
            else:
                result[key] = value
        else:
            result[key] = value
    return result


def _escape_toml_string(value: str) -> str:
    """Escape a string for use in a TOML basic (double-quoted) string."""
    return (
        value
        .replace("\\", "\\\\")
        .replace('"', '\\"')
        .replace("\n", "\\n")
        .replace("\t", "\\t")
    )


_BARE_KEY_OK = set(
    "abcdefghijklmnopqrstuvwxyz"
    "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
    "0123456789"
    "_-"
)


def _quote_key(key: str) -> str:
    """Quote a TOML key if it is not a valid bare key."""
    if all(c in _BARE_KEY_OK for c in key) and key:
        return key
    return f'"{_escape_toml_string(key)}"'


def _toml_scalar(value) -> str:  # noqa: ANN001
    """Format a single TOML scalar value (bool, int, float, str)."""
    if isinstance(value, bool):
        return "true" if value else "false"
    if isinstance(value, (int, float)):
        return str(value)
    return f'"{_escape_toml_string(value)}"'


def _toml_value_line(key: str, value) -> str:  # noqa: ANN001
    """Format a single TOML key = value line."""
    qkey = _quote_key(key)
    if isinstance(value, list):
        if not value:
            return f"{qkey} = []"
        items = "\n".join(
            f"    {_toml_scalar(v)}," for v in value
        )
        return f"{qkey} = [\n{items}\n]"
    return f"{qkey} = {_toml_scalar(value)}"


def _serialize_toml(data: dict, prefix: str = "") -> str:
    """Serialize a dict tree to TOML text.

    Handles the flat-ish structure used by agent-sandbox config:
    top-level tables (possibly dotted), with string / bool / int /
    string-list values.  Comments are not preserved.
    """
    lines: list[str] = []

    # Write scalar/array keys at this level
    has_scalars = any(not isinstance(v, dict) for v in data.values())
    if has_scalars and prefix:
        lines.append(f"[{prefix}]")

    for key, value in data.items():
        if isinstance(value, dict):
            continue
        lines.append(_toml_value_line(key, value))

    # Write sub-tables
    for key, value in data.items():
        if not isinstance(value, dict):
            continue
        sub_prefix = f"{prefix}.{key}" if prefix else key
        sub = _serialize_toml(value, sub_prefix)
        if sub.strip():
            if lines and lines[-1] != "":
                lines.append("")
            lines.append(sub)

    return "\n".join(lines)


def _apply_toml_suggestions(
    config_path: Path, toml_fragment: str,
) -> bool:
    """Merge TOML suggestions into an existing config file.

    Parses both the existing config and the suggestions, deep-merges
    them (extending lists, preserving existing keys), and writes back.
    A backup is saved alongside the config.
    Returns True on success, False on failure.
    """
    try:
        with open(config_path, "rb") as fh:
            existing = tomllib.load(fh)

        suggestions = tomllib.loads(toml_fragment)

        merged = _deep_merge_toml(existing, suggestions)

        # Backup before overwriting
        backup = config_path.with_suffix(".toml.bak")
        shutil.copy2(config_path, backup)

        with open(config_path, "w") as fh:
            fh.write(_serialize_toml(merged))
            fh.write("\n")

        return True
    except (OSError, tomllib.TOMLDecodeError) as exc:
        print(
            f"Error updating {config_path}: {exc}",
            file=sys.stderr,
        )
        return False


def cmd_learn(args) -> None:
    """Run agent under strace to learn its access patterns."""
    # 1. Validate strace is available
    if shutil.which("strace") is None:
        print("Error: strace not found.", file=sys.stderr)
        print(
            "Install with:  sudo dnf install strace  "
            "(or apt install strace)",
            file=sys.stderr,
        )
        sys.exit(1)

    # 2. Validate bwrap
    check_bwrap()

    # 3. Load config
    config, config_path = load_config()
    project_dir = Path.cwd().resolve()

    # 4. Resolve agent
    agent_name = args.agent
    agent_cfg = resolve_agent_config(config, agent_name)

    # Ensure git wrapper exists
    if config.get("security", {}).get("block_git_push", True):
        ensure_git_wrapper()

    # 5. Resolve profile
    profile = args.profile
    if profile is None:
        dp = config.get("sandbox", {}).get("default_profile", "")
        profile = dp or None

    # 6. Build the permissive bwrap command
    bwrap_cmd = build_learn_bwrap_cmd(
        config, project_dir, agent_cfg,
        agent_name=agent_name, profile=profile,
    )

    # 7. Create temp file for strace output
    trace_fd, trace_file = tempfile.mkstemp(
        prefix="agent-sandbox-learn-", suffix=".strace",
    )
    os.close(trace_fd)

    # 8. Wrap with strace
    strace_cmd = [
        "strace",
        "-f",
        "-e", "trace=openat,openat2,connect,bind,execve",
        "-o", trace_file,
        "--",
    ] + bwrap_cmd

    # Print banner
    print("agent-sandbox learn")
    print(f"  config      {config_path}")
    print(f"  agent       {agent_name} ({agent_cfg['command']})")
    if profile:
        print(f"  profile     {profile}")
    print(f"  project     {project_dir}")
    print(f"  trace file  {trace_file}")
    print(
        f"  mode        permissive sandbox "
        f"(home writable for observation)"
    )
    if args.duration:
        print(f"  duration    {args.duration}s (auto-terminate)")
    print()
    print(
        "Starting agent under strace... "
        "(use the agent normally, then exit)"
    )
    print()

    # 9. Run the wrapped command
    start_time = time.monotonic()
    proc = None
    try:
        proc = subprocess.Popen(strace_cmd, cwd=str(project_dir))

        if args.duration:
            try:
                proc.wait(timeout=args.duration)
            except subprocess.TimeoutExpired:
                print(
                    f"\n\nDuration limit ({args.duration}s) reached, "
                    f"terminating agent..."
                )
                proc.send_signal(signal.SIGTERM)
                try:
                    proc.wait(timeout=10)
                except subprocess.TimeoutExpired:
                    proc.kill()
                    proc.wait()
        else:
            proc.wait()

    except KeyboardInterrupt:
        print("\n\nInterrupted, terminating agent...")
        if proc and proc.poll() is None:
            proc.send_signal(signal.SIGTERM)
            try:
                proc.wait(timeout=10)
            except subprocess.TimeoutExpired:
                proc.kill()
                proc.wait()

    elapsed = time.monotonic() - start_time

    # 10. Parse the trace
    print("\nParsing strace output...")
    strace_parser = StraceParser(
        trace_file,
        home_dir=str(Path.home()),
        project_dir=str(project_dir),
    )
    strace_parser.parse()
    categories = strace_parser.categorize()

    # 11. Generate suggestions
    additions, removals, toml_fragment = generate_config_suggestions(
        categories, config, agent_name, str(Path.home()),
    )
    # --compare shows over-permissive areas (removals); without it, only additions
    if not getattr(args, "compare", False):
        removals = []

    # 12. Save TOML fragment
    toml_output = args.output
    if toml_output is None:
        toml_fd, toml_output = tempfile.mkstemp(
            prefix="agent-sandbox-learn-suggestions-",
            suffix=".toml",
        )
        os.close(toml_fd)

    with open(toml_output, "w") as fh:
        fh.write(toml_fragment)

    # 13. Print report
    print_learn_report(
        categories, strace_parser.network, strace_parser.executables,
        additions, removals,
        agent_name=agent_name,
        duration_secs=elapsed,
        trace_file=trace_file,
        toml_output=toml_output,
    )

    # 14. Apply if requested
    if args.apply:
        print(f"Applying suggestions to {config_path}...")
        if _apply_toml_suggestions(config_path, toml_fragment):
            print(f"Suggestions merged into {config_path}")
            backup = config_path.with_suffix(".toml.bak")
            print(f"Backup saved to {backup}")
        else:
            print("Failed to apply suggestions.", file=sys.stderr)
            sys.exit(1)


