def get_project_hash(project_dir: Path) -> str:
    """Deterministic short hash of the project path for snapshot namespacing."""
    canonical = str(project_dir.resolve())
    return hashlib.sha256(canonical.encode()).hexdigest()[:12]


def create_snapshot(
    source_dir: Path,
    snapshot_base_dir: Path,
    exclude: list[str] | None = None,
    link_dest: Path | None = None,
) -> Path:
    """Create an rsync --link-dest snapshot.

    source_dir: directory to snapshot
    snapshot_base_dir: e.g., ~/.agent-sandbox/snapshots/projects/<hash>/
    exclude: list of dir names to exclude
    link_dest: previous snapshot dir for hardlink dedup
    Returns: path to created snapshot directory (named by ISO timestamp)
    """
    if shutil.which("rsync") is None:
        print(
            "Error: rsync not found. Install rsync to use snapshots.",
            file=sys.stderr,
        )
        sys.exit(1)

    timestamp = datetime.now().strftime("%Y%m%dT%H%M%S")
    dest = snapshot_base_dir / timestamp
    dest.mkdir(parents=True, exist_ok=True)

    rsync_cmd: list[str] = ["rsync", "-a"]

    if link_dest and link_dest.is_dir():
        rsync_cmd.append(f"--link-dest={link_dest}")

    for pattern in (exclude or []):
        rsync_cmd.append(f"--exclude={pattern}")

    # rsync needs trailing slash on source to copy contents
    rsync_cmd.append(str(source_dir).rstrip("/") + "/")
    rsync_cmd.append(str(dest) + "/")

    result = subprocess.run(rsync_cmd, capture_output=True, text=True)
    if result.returncode != 0:
        print(
            f"Error: rsync failed (exit {result.returncode}): "
            f"{result.stderr.strip()}",
            file=sys.stderr,
        )
        if dest.exists():
            shutil.rmtree(dest)
        sys.exit(1)

    return dest


def list_snapshots(
    snapshot_base_dir: Path,
) -> list[tuple[str, Path, int]]:
    """List available snapshots sorted by timestamp.

    Returns list of (timestamp_str, path, size_bytes).
    """
    if not snapshot_base_dir.exists():
        return []

    snapshots: list[tuple[str, Path, int]] = []
    for entry in sorted(snapshot_base_dir.iterdir()):
        if entry.is_dir() and len(entry.name) >= 15:
            try:
                datetime.strptime(entry.name[:15], "%Y%m%dT%H%M%S")
            except ValueError:
                continue
            size = get_snapshot_size(entry)
            snapshots.append((entry.name, entry, size))

    return snapshots


def prune_snapshots(snapshot_base_dir: Path, max_count: int) -> int:
    """Remove oldest snapshots exceeding max_count. Returns number removed."""
    snaps = list_snapshots(snapshot_base_dir)
    if len(snaps) <= max_count:
        return 0

    removed = 0
    to_remove = snaps[: len(snaps) - max_count]
    for _ts, path, _sz in to_remove:
        try:
            shutil.rmtree(path)
            removed += 1
        except FileNotFoundError:
            pass

    return removed


def get_snapshot_size(snapshot_dir: Path) -> int:
    """Get disk usage of a snapshot in bytes."""
    total = 0
    try:
        for f in snapshot_dir.rglob("*"):
            if f.is_file():
                try:
                    total += f.stat().st_size
                except OSError:
                    pass
    except OSError:
        pass
    return total


def _resolve_config_dir(config: dict, agent_name: str) -> Path | None:
    """Resolve the agent config directory path from sandbox config."""
    if agent_name == "claude":
        claude_conf = config.get("claude", {})
        if claude_conf.get("use_real_config", False):
            return Path.home() / ".claude"
        return expand(
            claude_conf.get(
                "config_dir", "~/.agent-sandbox/claude-config",
            )
        )

    agent_cfg = resolve_agent_config(config, agent_name)
    for d in (
        agent_cfg.get("home_rw_dirs", [])
        + agent_cfg.get("home_ro_dirs", [])
    ):
        full = Path.home() / d
        if full.exists():
            return full
    return None


def _get_snapshot_config(config: dict) -> dict:
    """Read [snapshot] section from config with defaults."""
    snap_conf = config.get("snapshot", {})
    return {
        "auto_project": snap_conf.get("auto_project", False),
        "auto_config": snap_conf.get("auto_config", True),
        "max_project_snapshots": snap_conf.get(
            "max_project_snapshots", 3,
        ),
        "max_config_snapshots": snap_conf.get(
            "max_config_snapshots", 5,
        ),
        "project_exclude": snap_conf.get(
            "project_exclude", list(DEFAULT_PROJECT_EXCLUDES),
        ),
    }


def _get_project_snapshot_base(project_dir: Path) -> Path:
    """Return snapshot base dir for a project."""
    phash = get_project_hash(project_dir)
    return SNAPSHOT_DIR / "projects" / phash


def _get_config_snapshot_base(agent_name: str) -> Path:
    """Return snapshot base dir for an agent's config."""
    return SNAPSHOT_DIR / "configs" / agent_name


def _latest_snapshot(snapshot_base_dir: Path) -> Path | None:
    """Return the path of the most recent snapshot, or None."""
    snaps = list_snapshots(snapshot_base_dir)
    if snaps:
        return snaps[-1][1]
    return None


def _find_snapshot_by_timestamp(
    snapshot_base_dir: Path,
    timestamp: str,
) -> Path | None:
    """Find a snapshot matching a timestamp prefix."""
    snaps = list_snapshots(snapshot_base_dir)
    for ts, path, _sz in snaps:
        if ts.startswith(timestamp) or ts == timestamp:
            return path
    return None


def _auto_snapshot(config: dict, project_dir: Path, agent_name: str) -> None:
    """Create auto-snapshots before sandbox launch (called from cmd_run)."""
    snap_conf = _get_snapshot_config(config)

    if snap_conf["auto_config"]:
        config_dir = _resolve_config_dir(config, agent_name)
        if config_dir and config_dir.exists():
            base = _get_config_snapshot_base(agent_name)
            link = _latest_snapshot(base)
            try:
                snap_path = create_snapshot(
                    config_dir, base, link_dest=link,
                )
                prune_snapshots(base, snap_conf["max_config_snapshots"])
                print(f"  auto-snap   config {snap_path.name}")
            except SystemExit:
                print(
                    "  auto-snap   config FAILED (continuing)",
                    file=sys.stderr,
                )

    if snap_conf["auto_project"]:
        if project_dir.is_dir():
            base = _get_project_snapshot_base(project_dir)
            link = _latest_snapshot(base)
            excludes = snap_conf["project_exclude"]
            try:
                snap_path = create_snapshot(
                    project_dir, base,
                    exclude=excludes, link_dest=link,
                )
                prune_snapshots(
                    base, snap_conf["max_project_snapshots"],
                )
                print(f"  auto-snap   project {snap_path.name}")
            except SystemExit:
                print(
                    "  auto-snap   project FAILED (continuing)",
                    file=sys.stderr,
                )


