def cmd_proxy_status(args) -> None:
    """Show credential proxy status."""
    pid_file = SANDBOX_DIR / "proxy.pid"

    print("agent-sandbox proxy-status\n")

    if not pid_file.exists():
        print("  status        not running (no PID file)")
        print(f"  pid file      {pid_file}")
        return

    try:
        info = json.loads(pid_file.read_text())
    except (json.JSONDecodeError, OSError) as exc:
        print(f"  status        error reading PID file: {exc}")
        return

    pid = info.get("pid", 0)
    port = info.get("port", 0)
    start_ts = info.get("start_time", 0)
    rules = info.get("rules", [])

    # Check if process is still alive.
    alive = False
    if pid:
        try:
            os.kill(pid, 0)
            alive = True
        except ProcessLookupError:
            pass
        except PermissionError:
            alive = True  # Process exists but we lack permission.

    if alive:
        print(f"  status        running")
    else:
        print(f"  status        stale (process {pid} not found)")

    print(f"  pid           {pid}")
    print(f"  port          {port}")

    if start_ts:
        dt = datetime.fromtimestamp(start_ts)
        elapsed = time.time() - start_ts
        hours, remainder = divmod(int(elapsed), 3600)
        minutes, seconds = divmod(remainder, 60)
        print(f"  started       {dt.strftime('%Y-%m-%d %H:%M:%S')}")
        print(f"  uptime        {hours}h {minutes}m {seconds}s")

    if rules:
        print(f"  rules         {len(rules)} configured:")
        for r in rules:
            target = r.get("upstream_base") or r.get("domain", "?")
            header = r.get("header_name", "?")
            print(f"                  {target} ({header})")
    else:
        print(f"  rules         none configured")

    if not alive:
        print(f"\n  Note: PID file is stale.  Remove with:")
        print(f"    rm {pid_file}")


# ---------------------------------------------------------------------------
# Reusable directory comparison engine
# ---------------------------------------------------------------------------

def _matches_any_exclude(rel_path: Path, excludes: list[str]) -> bool:
    """Check if any component of rel_path matches an exclude pattern."""
    for part in rel_path.parts:
        for pattern in excludes:
            if fnmatch.fnmatch(part, pattern):
                return True
    return False


def compute_dir_diff(
    source_dir: Path,
    target_dir: Path,
    exclude: list[str] | None = None,
) -> list[tuple[Path, str, list[str]]]:
    """Compare two directory trees.

    Returns list of (rel_path, status, unified_diff_lines).
    status: 'created', 'modified', 'deleted', 'unchanged'
    exclude: list of glob patterns to skip (e.g., ['.git', 'node_modules'])

    Semantics: source_dir is the baseline (old), target_dir is the current (new).
    'created'  = exists only in target_dir
    'deleted'  = exists only in source_dir
    'modified' = exists in both but differs
    """
    excludes = exclude or []
    source_files: set[Path] = set()
    target_files: set[Path] = set()

    if source_dir.exists():
        for f in source_dir.rglob("*"):
            if f.is_file():
                rel = f.relative_to(source_dir)
                if not _matches_any_exclude(rel, excludes):
                    source_files.add(rel)

    if target_dir.exists():
        for f in target_dir.rglob("*"):
            if f.is_file():
                rel = f.relative_to(target_dir)
                if not _matches_any_exclude(rel, excludes):
                    target_files.add(rel)

    results: list[tuple[Path, str, list[str]]] = []

    for rel in sorted(source_files | target_files):
        sf = source_dir / rel
        tf = target_dir / rel

        if rel in source_files and rel not in target_files:
            results.append((rel, "deleted", []))
            continue
        if rel not in source_files and rel in target_files:
            results.append((rel, "created", []))
            continue

        # Both exist -- compare contents
        try:
            s_bytes = sf.read_bytes()
            t_bytes = tf.read_bytes()
        except (PermissionError, OSError):
            results.append((rel, "unchanged", []))
            continue

        if s_bytes == t_bytes:
            results.append((rel, "unchanged", []))
            continue

        # Generate unified diff for text files
        diff_lines: list[str] = []
        try:
            s_text = sf.read_text().splitlines(keepends=True)
            t_text = tf.read_text().splitlines(keepends=True)
            diff_lines = list(unified_diff(
                s_text, t_text,
                fromfile=f"source/{rel}",
                tofile=f"target/{rel}",
            ))
        except (UnicodeDecodeError, PermissionError):
            diff_lines = [f"  binary files differ: {rel}\n"]

        results.append((rel, "modified", diff_lines))

    return results


def print_dir_diff(
    diff_results: list[tuple[Path, str, list[str]]],
    source_label: str = "source",
    target_label: str = "target",
) -> bool:
    """Print a human-readable diff summary. Returns True if any differences found."""
    has_diff = False
    for rel, status, diff_lines in diff_results:
        if status == "unchanged":
            continue
        has_diff = True
        if status == "deleted":
            print(f"--- only in {source_label}: {rel}")
        elif status == "created":
            print(f"+++ only in {target_label}: {rel}")
        elif status == "modified":
            if diff_lines:
                for line in diff_lines:
                    print(line, end="")
                print()
    return has_diff


def interactive_review(
    diff_results: list[tuple[Path, str, list[str]]],
    source_dir: Path,
    target_dir: Path,
    action_verb: str = "apply",
) -> list[tuple[Path, str]]:
    """Present each changed file to user, collect per-file accept/reject.

    Returns list of (rel_path, decision) where decision is 'accept' or 'reject'.
    """
    changed = [(rel, status, diff_lines)
               for rel, status, diff_lines in diff_results
               if status != "unchanged"]
    if not changed:
        return []

    print(f"Found {len(changed)} changed file(s):\n")
    decisions: list[tuple[Path, str]] = []

    for rel, status, diff_lines in changed:
        if status == "created":
            label = "NEW"
        elif status == "deleted":
            label = "DEL"
        else:
            label = "MOD"
        print(f"  [{label}] {rel}")

        while True:
            try:
                ch = input(
                    f"    {action_verb}? (y)es / (n)o / (d)iff / (q)uit: "
                ).strip().lower()
            except (EOFError, KeyboardInterrupt):
                accepted = sum(1 for _, d in decisions if d == "accept")
                print(f"\nAborted. Accepted {accepted} file(s).")
                return decisions
            if ch == "d":
                if diff_lines:
                    for line in diff_lines:
                        print(line, end="")
                    print()
                else:
                    _print_file_diff(
                        source_dir / rel, target_dir / rel,
                        f"source/{rel}", f"target/{rel}",
                    )
            elif ch == "y":
                decisions.append((rel, "accept"))
                break
            elif ch == "n":
                decisions.append((rel, "reject"))
                break
            elif ch == "q":
                accepted = sum(1 for _, d in decisions if d == "accept")
                print(f"\nAborted. Accepted {accepted} file(s).")
                return decisions

    return decisions


def apply_diff_actions(
    actions: list[tuple[Path, str]],
    source_dir: Path,
    target_dir: Path,
) -> int:
    """Apply accepted actions from an interactive_review result.

    For merge (sandbox->real): source_dir=real, target_dir=sandbox
      - 'created' in target: copy target->source
      - 'modified': copy target->source
      - 'deleted' from source: remove from source

    For restore (snapshot->current): source_dir=snapshot, target_dir=current
      - copy from source to target for accepted changes

    Returns count of applied files.
    """
    applied = 0
    for rel, decision in actions:
        if decision != "accept":
            continue
        src_file = source_dir / rel
        tgt_file = target_dir / rel

        if tgt_file.exists():
            src_file.parent.mkdir(parents=True, exist_ok=True)
            shutil.copy2(tgt_file, src_file)
        else:
            if src_file.exists():
                src_file.unlink()
        applied += 1
        print(f"    applied: {rel}")

    return applied


# Legacy helpers -- used by cmd_diff/cmd_merge and cmd_status

def _collect_changes(real: Path, sand: Path) -> list[tuple[str, Path]]:
    """Collect changes between real and sandbox dirs (legacy wrapper)."""
    diff_results = compute_dir_diff(real, sand)
    changes: list[tuple[str, Path]] = []
    for rel, status, _diff_lines in diff_results:
        if status == "created":
            changes.append(("new", rel))
        elif status == "modified":
            changes.append(("modified", rel))
    return changes


def _print_file_diff(fa: Path, fb: Path, la: str, lb: str) -> bool:
    """Print unified diff between two files. Returns True if differences found."""
    try:
        a = fa.read_text().splitlines(keepends=True) if fa.exists() else []
        b = fb.read_text().splitlines(keepends=True) if fb.exists() else []
        diff = list(unified_diff(a, b, fromfile=la, tofile=lb))
        if diff:
            for line in diff:
                print(line, end="")
            print()
            return True
    except (UnicodeDecodeError, PermissionError):
        try:
            if fa.stat().st_size != fb.stat().st_size:
                print(f"  binary differ: {la} vs {lb}")
                return True
        except OSError:
            pass
    return False


def _pretty_print_cmd(cmd: list[str]) -> None:
    """Print a bwrap command in readable multi-line form."""
    i = 0
    while i < len(cmd):
        if cmd[i] == "--":
            print("  --")
            i += 1
            if i < len(cmd):
                print(f"  {' '.join(shlex.quote(c) for c in cmd[i:])}")
            break
        tok = cmd[i]
        if tok.startswith("--"):
            parts = [tok]
            i += 1
            while i < len(cmd) and not cmd[i].startswith("--"):
                parts.append(shlex.quote(cmd[i]))
                i += 1
            print(f"  {' '.join(parts)} \\")
        else:
            print(f"  {shlex.quote(tok)} \\")
            i += 1




