def main() -> None:
    _check_migration()
    parser = argparse.ArgumentParser(
        prog="agent-sandbox",
        description="Secure bubblewrap sandbox for AI coding agents.",
    )
    sub = parser.add_subparsers(dest="command")

    # init
    p_init = sub.add_parser("init", help="Initialise sandbox environment")
    p_init.add_argument("-f", "--force", action="store_true",
                        help="Overwrite existing config and files")
    p_init.add_argument("--real-config", action="store_true",
                        help="Use real ~/.claude directly (set use_real_config=true)")

    # run
    p_run = sub.add_parser("run", help="Run an agent inside the sandbox")
    p_run.add_argument("-p", "--project", default=".",
                       help="Project directory (default: cwd)")
    p_run.add_argument("-a", "--agent", default="claude",
                       help="Agent to run (default: claude). "
                            "Looks up [agents.<name>] in config.")
    p_run.add_argument("-P", "--profile", default=None,
                       help="Provider profile name (defined in config.toml)")
    p_run.add_argument("--log", action="store_true", default=None,
                       help="Enable session transcript logging")
    p_run.add_argument("--no-log", action="store_false", dest="log",
                       help="Disable session transcript logging")
    p_run.add_argument("--safe", action="store_true",
                       help="Disable --dangerously-skip-permissions for this run")
    p_run.add_argument("--dry-run", action="store_true",
                       help="Print bwrap command without executing")
    p_run.add_argument("--rw", action="append", default=[],
                       metavar="DIR", help="Extra read-write directory for this run (repeatable)")
    p_run.add_argument("--ro", action="append", default=[],
                       metavar="DIR", help="Extra read-only directory for this run (repeatable)")
    p_run.add_argument("--id", default=None, metavar="ID",
                       help="Agent ID (sets LINCE_AGENT_ID env var inside sandbox)")

    # diff
    sub.add_parser("diff",
                   help="Show differences between sandbox and real config")

    # merge
    sub.add_parser("merge",
                   help="Interactive merge: sandbox config -> real ~/.claude")

    # status
    sub.add_parser("status", help="Show sandbox status")

    # ---- Split argv on '--' so extra args go to the agent -------------------
    argv = sys.argv[1:]
    if "--" in argv:
        sep = argv.index("--")
        our_argv = argv[:sep]
        agent_extra = argv[sep + 1:]
    else:
        our_argv = argv
        agent_extra = []

    args, unknown = parser.parse_known_args(our_argv)

    if args.command is None:
        parser.print_help()
        sys.exit(0)

    if args.command == "run":
        # Unknown options pass through to the agent CLI
        agent_extra = unknown + agent_extra
    elif unknown:
        parser.error(f"unrecognized arguments: {' '.join(unknown)}")

    dispatch = {
        "init": lambda: cmd_init(args),
        "run": lambda: cmd_run(args, agent_extra),
        "diff": lambda: cmd_diff(args),
        "merge": lambda: cmd_merge(args),
        "status": lambda: cmd_status(args),
    }
    dispatch[args.command]()


if __name__ == "__main__":
    main()
