def cmd_merge(args) -> None:
    try:
        config, _ = load_config()
    except SystemExit:
        config = {}
    if config.get("claude", {}).get("use_real_config", False):
        print("merge disabled: using real ~/.claude (use_real_config = true)")
        return

    real = Path.home() / ".claude"
    sand = SANDBOX_DIR / "claude-config"
    if not sand.exists():
        print("No sandbox config. Run 'agent-sandbox init'."); return

    # Collect changes
    changes = _collect_changes(real, sand)
    if not changes:
        print("No changes to merge."); return

    print(f"Found {len(changes)} changed file(s):\n")
    merged = 0
    for kind, rel in changes:
        label = "NEW" if kind == "new" else "MOD"
        print(f"  [{label}] {rel}")
        while True:
            try:
                ch = input("    apply? (y)es / (n)o / (d)iff / (q)uit: ").strip().lower()
            except (EOFError, KeyboardInterrupt):
                print(f"\nAborted. Applied {merged} file(s)."); return
            if ch == "d":
                _print_file_diff(real / rel, sand / rel, f"real/{rel}", f"sandbox/{rel}")
            elif ch == "y":
                dest = real / rel
                dest.parent.mkdir(parents=True, exist_ok=True)
                shutil.copy2(sand / rel, dest)
                print("    applied.")
                merged += 1
                break
            elif ch == "n":
                break
            elif ch == "q":
                print(f"\nAborted. Applied {merged} file(s)."); return
    print(f"\nMerge complete: {merged}/{len(changes)} file(s) applied.")


