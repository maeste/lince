        else:
            base = _get_config_snapshot_base(agent_name)
            link = _latest_snapshot(base)
            print(f"Creating config snapshot: {config_dir}")
            snap_path = create_snapshot(
                config_dir, base, link_dest=link,
            )
            sz = get_snapshot_size(snap_path)
            print(
                f"  saved: {snap_path.name} ({human_size(sz)})",
            )
            removed = prune_snapshots(
                base, snap_conf["max_config_snapshots"],
            )
            if removed:
                print(f"  pruned {removed} old snapshot(s)")


