def find_config() -> Path:
    """Find config.toml: current directory first, then home.

    Search order:
      1. ./.agent-sandbox/config.toml  (project-local)
      2. ~/.agent-sandbox/config.toml  (global)

    Returns the first existing path, or exits with a clear error.
    """
    candidates = [
        Path.cwd() / ".agent-sandbox" / "config.toml",
        SANDBOX_DIR / "config.toml",
    ]
    for p in candidates:
        if p.is_file():
            return p

    print("Error: no config.toml found.", file=sys.stderr)
    print("Searched in:", file=sys.stderr)
    for p in candidates:
        print(f"  {p}", file=sys.stderr)
    print(f"\nCreate a config.toml in one of these locations:", file=sys.stderr)
    print(f"  .agent-sandbox/config.toml   (project-local, this directory)",
          file=sys.stderr)
    print(f"  ~/.agent-sandbox/config.toml (global, shared across projects)",
          file=sys.stderr)
    print(f"\nRun 'agent-sandbox init' to create a default config.",
          file=sys.stderr)
    sys.exit(1)


def load_config() -> tuple[dict, Path]:
    """Load and return the sandbox configuration and its path.

    If both ~/.agent-sandbox/config.toml (global) and
    ./.agent-sandbox/config.toml (project-local) exist, the project-local
    config is deep-merged on top of the global one: dicts recurse, lists
    append-and-dedup, scalars from the local config replace global ones.
    The local path is returned so user-facing messages point at the file
    being edited.
    """
    global_path = SANDBOX_DIR / "config.toml"
    local_path = Path.cwd() / ".agent-sandbox" / "config.toml"

    if global_path.is_file() and local_path.is_file():
        with open(global_path, "rb") as fh:
            base = tomllib.load(fh)
        with open(local_path, "rb") as fh:
            overlay = tomllib.load(fh)
        print(
            f"config: merged {global_path} + {local_path}",
            file=sys.stderr,
        )
        return _deep_merge_toml(base, overlay), local_path

    config_path = find_config()
    with open(config_path, "rb") as fh:
        return tomllib.load(fh), config_path


# Keys whose list values should be APPENDED (not replaced) when overlaying a
# sandbox-policy fragment on top of the user's resolved config. New entries
# are de-duplicated against what's already in the base list.
_SANDBOX_LEVEL_LIST_APPEND_KEYS = frozenset({
    "home_ro_dirs", "home_rw_dirs", "ro_dirs", "extra_rw",
    # [security].allow_domains is also append-merged so a custom level can
    # extend (e.g. "paranoid + pypi") without restating the base set.
    "allow_domains",
    # [env].passthrough extends host-env vars exposed in the sandbox so
    # fragments can add tool-specific tokens (e.g. permissive ships
    # GH_TOKEN / GITHUB_TOKEN so `gh` keeps its env-based auth working).
    "passthrough",
})


def _find_fragment_path(name: str, agent: str) -> Path | None:
    """Return the resolved absolute path of a fragment, or None if not found.

    Search order, each tried as <agent>-<name>.toml then <name>.toml:
      1. ./.agent-sandbox/profiles/   (project-local override)
      2. ~/.agent-sandbox/profiles/   (user-installed)
      3. <script-dir>/profiles/       (built-in, ships with the script)
    """
    script_dir = Path(__file__).resolve().parent
    base_dirs = [
        Path.cwd() / ".agent-sandbox" / "profiles",
        SANDBOX_DIR / "profiles",
        script_dir / "profiles",
    ]
    for d in base_dirs:
        for candidate in (f"{agent}-{name}.toml", f"{name}.toml"):
            p = d / candidate
            if p.is_file():
                return p.resolve()
    return None


def _resolve_fragment_extends(
    name: str, agent: str, *, _chain: list[Path] | None = None
) -> dict:
    """Recursively load a fragment, resolving ``extends`` inheritance.

    The optional top-level field ``extends = "<parent-name>"`` in a fragment
    causes the parent to be resolved first (same 3-dir, agent-prefix lookup),
    then the child is deep-merged on top using ``merge_sandbox_level``
    semantics (whitelisted append for list keys, replace for others).

    *_chain* tracks the absolute paths of all fragments in the current
    resolution chain; a path appearing twice is a cycle → hard error.
    A referenced parent that cannot be found is also a hard error.

    The ``extends`` key is stripped from the returned dict.
    """
    if _chain is None:
        _chain = []

    path = _find_fragment_path(name, agent)
    if path is None:
        script_dir = Path(__file__).resolve().parent
        searched = "\n".join(
            f"  {d / c}"
            for d in [
                Path.cwd() / ".agent-sandbox" / "profiles",
                SANDBOX_DIR / "profiles",
                script_dir / "profiles",
            ]
            for c in (f"{agent}-{name}.toml", f"{name}.toml")
        )
        print(
            f"Error: sandbox-level fragment '{name}' not found.\nSearched:\n{searched}",
            file=sys.stderr,
        )
        sys.exit(1)

    if path in _chain:
        idx = _chain.index(path)
        cycle = " → ".join(p.name for p in _chain[idx:]) + f" → {path.name}"
        print(f"Error: fragment cycle detected: {cycle}", file=sys.stderr)
        sys.exit(1)

    _chain.append(path)

    with open(path, "rb") as fh:
        fragment = tomllib.load(fh)

    parent_name = fragment.pop("extends", None)
    if parent_name is not None:
        if not isinstance(parent_name, str):
            print(
                f"Error: 'extends' in {path.name} must be a string, "
                f"got {type(parent_name).__name__}",
                file=sys.stderr,
            )
            sys.exit(1)
        parent = _resolve_fragment_extends(parent_name, agent, _chain=_chain)
        return merge_sandbox_level(parent, fragment)

    return fragment


def load_sandbox_level_fragment(level: str, agent: str = "claude") -> dict | None:
    """Locate and load a sandbox-policy fragment for the given level name.

    Tries the agent-specific name first (``<agent>-<level>.toml``) so the
    shipped fragments like ``claude-paranoid.toml`` are picked up, then
    falls back to the bare level name (``<level>.toml``) so users can
    write a single cross-agent fragment when they want one.

    Search order, each tried as <agent>-<level>.toml then <level>.toml:
      1. ./.agent-sandbox/profiles/   (project-local override)
      2. ~/.agent-sandbox/profiles/   (user-installed)
      3. <script-dir>/profiles/       (built-in, ships with the script)

    If the fragment contains ``extends = "<parent-name>"`` at the top level,
    the parent is resolved recursively (same lookup) and deep-merged first;
    the child is then merged on top using ``merge_sandbox_level`` semantics.
    Cycles and missing parents are hard errors.

    Returns the fully-resolved fragment dict, or None if the top-level
    fragment file was not found (caller surfaces a user-visible error).
    """
    if not level:
        return None
    if _find_fragment_path(level, agent) is None:
        return None
    return _resolve_fragment_extends(level, agent)


def merge_sandbox_level(base: dict, overlay: dict) -> dict:
    """Deep-merge a sandbox-policy fragment into the loaded config.

    Dict values are merged recursively. List values for keys in
    ``_SANDBOX_LEVEL_LIST_APPEND_KEYS`` are appended (preserving order,
    de-duplicating); other lists and scalars are replaced by the overlay.
    Returns a new dict; does not mutate inputs.
    """
    result = dict(base)
    for key, ov_value in overlay.items():
        if (
            key in result
            and isinstance(result[key], dict)
            and isinstance(ov_value, dict)
        ):
            result[key] = merge_sandbox_level(result[key], ov_value)
        elif (
            key in result
            and isinstance(result[key], list)
            and isinstance(ov_value, list)
            and key in _SANDBOX_LEVEL_LIST_APPEND_KEYS
        ):
            merged = list(result[key])
            for item in ov_value:
                if item not in merged:
                    merged.append(item)
            result[key] = merged
        else:
            result[key] = ov_value
    return result


_agents_defaults_cache: dict[str, dict] | None = None


def find_agents_defaults() -> dict[str, dict]:
    """Locate and load agents-defaults.toml (cached after first call).

    Search order:
      1. ./.agent-sandbox/agents-defaults.toml  (project-local)
      2. ~/.agent-sandbox/agents-defaults.toml   (global)
      3. <script-dir>/agents-defaults.toml        (development / installed alongside script)

    Returns an empty dict if no file is found (caller falls back to hardcoded defaults).
    """
    global _agents_defaults_cache
    if _agents_defaults_cache is not None:
        return _agents_defaults_cache
    script_dir = Path(__file__).resolve().parent
    candidates = [
        Path.cwd() / ".agent-sandbox" / "agents-defaults.toml",
        SANDBOX_DIR / "agents-defaults.toml",
        script_dir / "agents-defaults.toml",
    ]
    for p in candidates:
        if p.is_file():
            with open(p, "rb") as fh:
                data = tomllib.load(fh)
            _agents_defaults_cache = data.get("agents", {})
            return _agents_defaults_cache
    _agents_defaults_cache = {}
    return _agents_defaults_cache


def resolve_profiles(config: dict, agent_name: str = "claude") -> dict:
    """Resolve profiles for a given agent, merging legacy and namespaced formats.

    Merge order (later wins):
      1. Legacy ``[profiles.*]`` — only included when agent_name is "claude"
      2. Namespaced ``[<agent_name>.profiles.*]``

    Returns a flat dict of profile_name → profile_config.
    """
    merged: dict = {}
    # Legacy [profiles.*] → attributed to "claude"
    if agent_name == "claude":
        merged.update(config.get("profiles", {}))
    # Namespaced [<agent>.profiles.*]
    agent_section = config.get(agent_name, {})
    if isinstance(agent_section, dict):
        namespaced = agent_section.get("profiles", {})
        if isinstance(namespaced, dict):
            merged.update(namespaced)
    return merged


def resolve_agent_config(config: dict, agent_name: str) -> dict:
    """Build a fully resolved agent configuration.

    Merge order (later wins):
      1. Per-key defaults (empty strings / lists / dicts / False)
      2. agents-defaults.toml  [agents.<name>]
      3. User config.toml      [agents.<name>]
      4. Legacy [claude] section (only when agent_name == "claude" and
         [agents.claude] is absent from user config)

    Returns a dict with all AGENT_CONFIG_KEYS guaranteed present.
    """
    # --- Layer 0: structural defaults for every key --------------------------
    base: dict = {
        "command": agent_name,
        "default_args": [],
        "env": {},
        "home_ro_dirs": [],
        "home_rw_dirs": [],
        "bwrap_conflict": False,
        "disable_inner_sandbox_args": [],
        # Subdirs bound to per-run ephemeral scratch dirs (see cmd_run §5c).
        "scratch_home_dirs": [],
        # Sibling files bound to per-run ephemeral scratch files (same plumbing).
        "scratch_home_files": [],
    }

    # --- Layer 1: shipped defaults from agents-defaults.toml -----------------
    shipped_agents = find_agents_defaults()
    shipped = shipped_agents.get(agent_name, {})

    # Special case: if no agents-defaults.toml found and agent is "claude",
    # use hardcoded fallback so existing setups keep working.
    if not shipped_agents and agent_name == "claude":
        shipped = dict(HARDCODED_CLAUDE_DEFAULTS)

    # --- Layer 2: user config [agents.<name>] --------------------------------
    user_agents = config.get("agents", {})
    user_agent = user_agents.get(agent_name, {})

    # --- Layer 3: backward compat — legacy [claude] section ------------------
    legacy: dict = {}
    if agent_name == "claude" and agent_name not in user_agents:
        claude_section = config.get("claude", {})
        if claude_section:
            # Map known [claude] keys to agent config keys.
            if "default_args" in claude_section:
                legacy["default_args"] = list(claude_section["default_args"])
            # config_dir and use_real_config are sandbox-level concerns,
            # not agent-level — they stay in [claude] and are read elsewhere.

    # --- Merge layers --------------------------------------------------------
    result = dict(base)
    for layer in (shipped, legacy, user_agent):
        for key in AGENT_CONFIG_KEYS:
            if key not in layer:
                continue
            val = layer[key]
            if isinstance(val, dict):
                # Merge dicts (env vars)
                result[key] = {**result.get(key, {}), **val}
            else:
                result[key] = val

    return result


def expand(p: str) -> Path:
    """Expand ~ and env vars."""
    return Path(os.path.expandvars(os.path.expanduser(p)))


_ENV_VAR_REF = re.compile(r"\$\{(\w+)\}|\$(\w+)")


def _expand_env_value(val) -> str:
    """Expand ``$VAR`` / ``${VAR}`` references in agent/profile/extra env values
    against the host environment.

    Lets ``[agents.X].env = { ZAI_API_KEY = "$ZAI_API_KEY" }`` (and the same
    pattern in ``[profiles.*.env]`` and ``[env.extra]``) resolve to the host's
    actual value at launch time. References to unset host vars expand to empty
    strings (shell semantics) — never to the literal ``$VAR`` text, which
    would otherwise leak inside the sandbox and look like a misconfigured key.
    Literal values without ``$VAR`` pass through unchanged, so
    ``GEMINI_FORCE_FILE_STORAGE = "true"`` still works.
    """
    s = str(val)
    return _ENV_VAR_REF.sub(
        lambda m: os.environ.get(m.group(1) or m.group(2), ""),
        s,
    )


def check_bwrap() -> None:
    """Verify bubblewrap is installed."""
    if shutil.which("bwrap") is None:
        print("Error: bubblewrap (bwrap) not found.", file=sys.stderr)
        print("Install with:  sudo dnf install bubblewrap", file=sys.stderr)
        sys.exit(1)


def detect_backends() -> dict[str, str]:
    """Detect available sandbox backends.

    Returns dict of {name: path_to_binary}.
    """
    backends: dict[str, str] = {}
    bwrap_path = shutil.which("bwrap")
    if bwrap_path:
        backends["agent-sandbox"] = bwrap_path
    nono_path = shutil.which("nono")
    if nono_path:
        backends["nono"] = nono_path
    return backends


def resolve_backend(config: dict) -> str:
    """Determine which sandbox backend to use.

    Returns "agent-sandbox" or "nono".  Exits with error if neither is available.

    NOTE: Keep auto-detection priority in sync with
    lince-dashboard/plugin/src/sandbox_backend.rs DetectedBackends::resolve().
    """
    backend_setting = config.get("sandbox", {}).get("backend", "auto")
    backends = detect_backends()

    if backend_setting == "auto":
        is_linux = sys.platform.startswith("linux")
        if is_linux and "agent-sandbox" in backends:
            return "agent-sandbox"
        if "nono" in backends:
            return "nono"
        if is_linux:
            print("Error: no sandbox backend found.", file=sys.stderr)
            print("Install bubblewrap: sudo dnf install bubblewrap", file=sys.stderr)
            print("Or install nono: https://github.com/always-further/nono", file=sys.stderr)
        else:
            print("Error: no sandbox backend found.", file=sys.stderr)
            print(
                "agent-sandbox requires Linux (bubblewrap). On macOS, install nono:",
                file=sys.stderr,
            )
            print("  brew install nono", file=sys.stderr)
            print("  https://github.com/always-further/nono", file=sys.stderr)
        sys.exit(1)
    elif backend_setting == "agent-sandbox":
        if "agent-sandbox" not in backends:
            print("Error: backend 'agent-sandbox' selected but bwrap not found.", file=sys.stderr)
            print("Install with:  sudo dnf install bubblewrap", file=sys.stderr)
            sys.exit(1)
        return "agent-sandbox"
    elif backend_setting == "nono":
        if "nono" not in backends:
            print("Error: backend 'nono' selected but nono not found.", file=sys.stderr)
            print("Install from: https://github.com/always-further/nono", file=sys.stderr)
            sys.exit(1)
        return "nono"
    else:
        print(f"Error: unknown backend '{backend_setting}'.", file=sys.stderr)
        print("Valid options: auto, agent-sandbox, nono", file=sys.stderr)
        sys.exit(1)


def build_nono_cmd(
    agent_name: str,
    project_dir: Path,
    agent_config: dict,
    agent_extra_args: list[str],
    safe_mode: bool = False,
    agent_id: str | None = None,
) -> list[str]:
    """Build nono run command for the given agent."""
    profile_name = f"lince-{agent_name}"
    cmd = ["nono", "run", "--profile", profile_name]
    cmd.extend(["--workdir", str(project_dir)])
    cmd.extend(["--allow-cwd"])

    cmd.append("--")
    cmd.append(agent_config.get("command", agent_name))

    default_args = list(agent_config.get("default_args", []))
    if safe_mode:
        # Remove --dangerously-skip-permissions if present
        default_args = [a for a in default_args if a != "--dangerously-skip-permissions"]
    cmd.extend(default_args)
    cmd.extend(agent_extra_args)
    return cmd


def generate_nono_profile(
    agent_name: str,
    agent_config: dict,
    config: dict,
    profile_name: str | None = None,
) -> tuple[dict, list[str]]:
    """Generate a nono profile dict from lince agent configuration.

    Returns (profile_dict, warnings_list).
    """
    warnings: list[str] = []

    # Determine if nono has a built-in profile to extend.
    # Agents without a specific nono profile extend "default" so they
    # get the base security groups (system_read, user_tools, etc.).
    nono_base = NONO_BUILTIN_PROFILES.get(agent_name, "default")
    profile: dict = {"extends": nono_base}
    nono_profile_name = f"lince-{agent_name}"
    profile["meta"] = {
        "name": nono_profile_name,
        "description": "Generated by lince agent-sandbox (nono-sync)",
    }

    # --- Filesystem ---
    sandbox_conf = config.get("sandbox", {})
    read_paths: list[str] = []
    write_paths: list[str] = []
    allow_paths: list[str] = ["$WORKDIR"]  # read+write

    # Fedora/RHEL use /etc/pki/tls for OpenSSL config (not /etc/ssl).
    # nono's system_read_linux group covers /etc/ssl but not /etc/pki/tls,
    # so Node.js/Python agents fail with "Permission denied" on openssl.cnf.
    if Path("/etc/pki/tls").is_dir():
        read_paths.append("/etc/pki/tls")

    # Tools installed via npm/pip to ~/.local/bin are often symlinks into
    # ~/.local/lib/node_modules/... — nono's user_tools group grants
    # ~/.local/bin but not ~/.local/lib, so the binary can't be read.
    local_lib = Path.home() / ".local" / "lib"
    if local_lib.is_dir():
        read_paths.append(str(local_lib))

    # ro_dirs from [sandbox]
    for d in sandbox_conf.get("ro_dirs", []):
        ep = str(expand(d))
        if ep not in read_paths:
            read_paths.append(ep)

    # home_ro_dirs from [sandbox]
    home = Path.home()
    for d in sandbox_conf.get("home_ro_dirs", []):
        full = str(home / d)
        if full not in read_paths:
            read_paths.append(full)

    # Agent-specific ro dirs
    for d in agent_config.get("home_ro_dirs", []):
        full = str(home / d)
        if full not in read_paths:
            read_paths.append(full)

    # Agent-specific rw dirs → allow (read+write) in nono
    for d in agent_config.get("home_rw_dirs", []):
        full = str(home / d)
        if full not in allow_paths:
            allow_paths.append(full)

    # extra_rw from [sandbox] → allow (read+write)
    for d in sandbox_conf.get("extra_rw", []):
        ep = str(expand(d))
        if ep not in allow_paths:
            allow_paths.append(ep)

    filesystem: dict = {}
    if allow_paths:
        filesystem["allow"] = allow_paths
    if read_paths:
        filesystem["read"] = read_paths
    if write_paths:
        filesystem["write"] = write_paths
    if filesystem:
        profile["filesystem"] = filesystem

    # --- Environment passthrough ---
    env_conf = config.get("env", {})
    passthrough = list(env_conf.get("passthrough", []))
    if passthrough:
        profile["environment"] = {"passthrough": passthrough}

    # --- Extra env vars ---
    # Collect env vars from agent config, profile env, and [env.extra]
    # and add them all to passthrough.  Credential isolation is handled
    # by agent-sandbox's credential proxy, not by the nono profile.
    all_env: dict[str, str] = {}

    # [env.extra]
    for var, val in env_conf.get("extra", {}).items():
        all_env[var] = _expand_env_value(val)

    # Profile env (if a profile is selected)
    if profile_name:
        profiles = resolve_profiles(config, agent_name)
        prof_data = profiles.get(profile_name, {})
        if isinstance(prof_data, dict):
            for var, val in prof_data.get("env", {}).items():
                all_env[var] = _expand_env_value(val)

    # Agent-level env
    for var, val in agent_config.get("env", {}).items():
        all_env[var] = _expand_env_value(val)

    for var in sorted(all_env):
        existing_pt = profile.get("environment", {}).get("passthrough", [])
        if var not in existing_pt:
            if "environment" not in profile:
                profile["environment"] = {"passthrough": []}
            if "passthrough" not in profile["environment"]:
                profile["environment"]["passthrough"] = []
            profile["environment"]["passthrough"].append(var)

    # --- Security ---
    # allowed_commands was deprecated in nono v0.33.0 (startup-only,
    # child processes bypass it).  Use filesystem grants and policy
    # groups for real enforcement instead.
    security: dict = {}
    security["signal_mode"] = "allow_same_sandbox"
    profile["security"] = security

    # --- Network ---
    # nono allows network by default; no profile section needed.
    # Use --block-net or network.block=true to deny it.

    # --- Warnings for untranslatable features ---
    if agent_config.get("bwrap_conflict"):
        warnings.append(
            f"[{agent_name}] bwrap_conflict=true has no nono equivalent "
            f"(nono handles nested sandboxes differently)"
        )

    if agent_config.get("disable_inner_sandbox_args"):
        warnings.append(
            f"[{agent_name}] disable_inner_sandbox_args has no nono equivalent"
        )

    snap_conf = config.get("snapshot", {})
    if snap_conf.get("auto_project") or snap_conf.get("auto_config"):
        warnings.append(
            "[snapshot] settings not applicable to nono "
            "(nono has built-in rollback via 'nono undo')"
        )

    return profile, warnings


def cmd_nono_sync(args) -> None:
    """Generate nono JSON profiles from lince agent configuration."""
    config, config_path = load_config()
    dry_run = args.dry_run

    # Determine which agents to sync
    if args.agent:
        agent_names = [args.agent]
    else:
        # Collect all known agent names from defaults + user config
        shipped = find_agents_defaults()
        user_agents = config.get("agents", {})
        all_names: set[str] = set(shipped.keys()) | set(user_agents.keys())
        if not all_names:
            all_names = {"claude"}
        agent_names = sorted(all_names)

    if not dry_run:
        NONO_PROFILE_DIR.mkdir(parents=True, exist_ok=True)

    print(f"nono-sync: generating profiles from {config_path}")
    if dry_run:
        print("  (dry-run mode — no files will be written)\n")
    else:
        print(f"  output: {NONO_PROFILE_DIR}/\n")

    # Resolve the profile name if any
    profile_name = getattr(args, "profile", None)
    if profile_name is None:
        profile_name = config.get("sandbox", {}).get("default_profile", "") or None

    all_warnings: list[str] = []

    for agent_name in agent_names:
        agent_cfg = resolve_agent_config(config, agent_name)
        profile, warnings = generate_nono_profile(
            agent_name, agent_cfg, config, profile_name=profile_name,
        )
        all_warnings.extend(warnings)

        profile_json = json.dumps(profile, indent=2) + "\n"
        nono_profile_name = f"lince-{agent_name}"
        out_file = NONO_PROFILE_DIR / f"{nono_profile_name}.json"

        print(f"  {nono_profile_name}:")
        if dry_run:
            print(profile_json)
        else:
            out_file.write_text(profile_json)
            print(f"    -> {out_file}")

    # Print warnings
    if all_warnings:
        # Deduplicate warnings
        seen: set[str] = set()
        print()
        for w in all_warnings:
            if w not in seen:
                seen.add(w)
                print(f"\033[33m\u26a0 {w}\033[0m")

    if not dry_run:
        print(f"\nDone. {len(agent_names)} profile(s) written to {NONO_PROFILE_DIR}/")
        print("Run agents with nono:  nono run --profile lince-<agent> -- <command>")


def human_size(n: int) -> str:
    for unit in ("B", "KB", "MB", "GB"):
        if n < 1024:
            return f"{n:.0f} {unit}"
        n /= 1024
    return f"{n:.1f} TB"


_home_path_dirs_cache: list[Path] | None = None
_home_path_entries_cache: list[Path] | None = None


def detect_home_path_dirs() -> list[Path]:
    """Return top-level $HOME sub-directories found in $PATH (cached)."""
    global _home_path_dirs_cache
    if _home_path_dirs_cache is not None:
        return _home_path_dirs_cache
    home = Path.home()
    seen: set[Path] = set()
    result: list[Path] = []
    for entry in os.environ.get("PATH", "").split(":"):
        p = Path(entry).resolve()
        try:
            rel = p.relative_to(home)
        except ValueError:
            continue
        top = home / rel.parts[0]
        if top not in seen and top.exists():
            seen.add(top)
            result.append(top)
    _home_path_dirs_cache = sorted(result)
    return _home_path_dirs_cache


def detect_home_path_entries() -> list[Path]:
    """Return all $PATH entries under $HOME, preserving the original deep paths (cached).

    Unlike detect_home_path_dirs() which collapses to top-level dirs (for mounting),
    this returns every original host PATH entry under $HOME.  Used to add deep
    subdirectories like ~/Applications/apache-maven-3.9.14/bin to the sandbox PATH
    when their top-level parent is already mounted read-only.
    """
    global _home_path_entries_cache
    if _home_path_entries_cache is not None:
        return _home_path_entries_cache
    home = Path.home()
    seen: set[Path] = set()
    result: list[Path] = []
    for entry in os.environ.get("PATH", "").split(":"):
        if not entry:
            continue
        p = Path(entry).resolve()
        try:
            p.relative_to(home)
        except ValueError:
            continue
        if p not in seen and p.is_dir():
            seen.add(p)
            result.append(p)
    _home_path_entries_cache = result
    return _home_path_entries_cache


# ---------------------------------------------------------------------------
# Gitconfig sanitiser
# ---------------------------------------------------------------------------

def sanitize_gitconfig(source: Path, dest: Path,
                       strip_patterns: list[str],
                       overrides: dict[str, str]) -> None:
    """Write a sanitised copy of *source* to *dest*."""
    if not source.exists():
        dest.write_text("# Auto-generated sanitized gitconfig\n")
        return

    compiled = [re.compile(pat, re.IGNORECASE) for pat in strip_patterns]
    lines = source.read_text().splitlines()
    out: list[str] = []
    skip = False

    for line in lines:
        m = re.match(r"\s*\[(.+)\]\s*$", line)
        if m:
            skip = any(rx.search(m.group(1)) for rx in compiled)
        if not skip:
            out.append(line)

    if overrides:
        out.append("")
        out.append("# agent-sandbox overrides")
        for key, val in overrides.items():
            section, _, name = key.rpartition(".")
            if section and name:
                out.append(f"[{section}]")
                out.append(f"\t{name} = {val}")

    dest.write_text("\n".join(out) + "\n")


# ---------------------------------------------------------------------------
# Git-push blocker wrapper
# ---------------------------------------------------------------------------

GIT_WRAPPER = """\
#!/bin/bash
# agent-sandbox: blocks git push
case "$1" in
    push)
        printf '\\033[31mgit push is blocked inside the sandbox.\\033[0m\\n' >&2
        exit 1
        ;;
    *)
        exec /usr/bin/git "$@"
        ;;
esac
"""


def ensure_git_wrapper() -> Path:
    """Create (or verify) the git-push-blocking wrapper script."""
    bin_dir = SANDBOX_DIR / "bin"
    bin_dir.mkdir(parents=True, exist_ok=True)
    wrapper = bin_dir / "git"
    try:
        if wrapper.exists() and wrapper.read_text() == GIT_WRAPPER:
            return bin_dir
    except OSError:
        pass
    wrapper.write_text(GIT_WRAPPER)
    wrapper.chmod(0o755)
    return bin_dir


# ---------------------------------------------------------------------------
# bwrap command builder
# ---------------------------------------------------------------------------

def build_bwrap_cmd(config: dict, project_dir: Path,
                    agent_extra_args: list[str],
                    log_file: Path | None = None,
                    profile: str | None = None,
                    safe_mode: bool = False,
                    extra_rw_cli: list[str] | None = None,
                    extra_ro_cli: list[str] | None = None,
                    agent_config: dict | None = None,
                    agent_id: str | None = None,
                    agent_name: str = "claude",
                    proxy_env: dict[str, str] | None = None,
                    scratch_binds: list[tuple[str, str]] | None = None) -> list[str]:
    home = str(Path.home())
    home_p = Path.home()
    sandbox = config.get("sandbox", {})
    claude_conf = config.get("claude", {})
    env_conf = config.get("env", {})
    sec = config.get("security", {})
    agent_cfg = agent_config or resolve_agent_config(config, agent_name)

    # Resolve profile
    prof: dict = {}
    if profile:
        profiles = resolve_profiles(config, agent_name)
        if profile not in profiles:
            avail = ", ".join(sorted(profiles)) if profiles else "(none defined)"
            print(f"Error: unknown profile '{profile}'.", file=sys.stderr)
            print(f"Available profiles: {avail}", file=sys.stderr)
            sys.exit(1)
        prof = profiles[profile]

    cmd: list[str] = ["bwrap"]

    # --- 1. Whole FS read-only -----------------------------------------------
    cmd += ["--ro-bind", "/", "/"]

    # --- 2. Fresh tmpfs for sensitive / temporary locations -------------------
    cmd += ["--tmpfs", "/tmp"]
    # Hide user runtime sockets (DBus, PipeWire) but keep
    # /run/systemd/resolve intact so DNS works (resolv.conf is a symlink
    # to /run/systemd/resolve/stub-resolv.conf on systemd distros).
    uid = os.getuid()
    runtime_dir = os.environ.get("XDG_RUNTIME_DIR", f"/run/user/{uid}")
    cmd += ["--tmpfs", f"/run/user/{uid}"]

    # --- 2b. Re-expose Zellij socket dir so hooks can use `zellij pipe` ------
    # Zellij 0.40+ stores sockets in $XDG_RUNTIME_DIR/zellij/ (not /tmp).
    zellij_socket_dir = os.path.join(runtime_dir, "zellij")
    if os.path.isdir(zellij_socket_dir):
        dest = f"/run/user/{uid}/zellij"
        cmd += ["--bind", zellij_socket_dir, dest]

    # --- 2c. Shared lince-dashboard status dir (hook writes, plugin reads) ----
    # The sandbox has its own tmpfs on /tmp, so we bind-mount a specific
    # directory so hooks can write status files visible to the host plugin.
    lince_status_dir = "/tmp/lince-dashboard"
    os.makedirs(lince_status_dir, exist_ok=True)
    cmd += ["--bind", lince_status_dir, lince_status_dir]

    # --- 2d. Re-expose Wayland socket so clipboard (wl-paste) works ----------
    wayland_display = os.environ.get("WAYLAND_DISPLAY", "wayland-0")
    wayland_socket = f"{runtime_dir}/{wayland_display}"
    if os.path.exists(wayland_socket):
        cmd += ["--ro-bind", wayland_socket, f"/run/user/{uid}/{wayland_display}"]
    cmd += ["--tmpfs", "/var/tmp"]
    cmd += ["--dev", "/dev"]
    cmd += ["--proc", "/proc"]

    # --- 3. Hide entire $HOME ------------------------------------------------
    cmd += ["--tmpfs", home]

    # --- 4. Read-only dirs (including user projects) -------------------------
    for d in sandbox.get("ro_dirs", []):
        ep = str(expand(d))
        if os.path.isdir(ep):
            cmd += ["--ro-bind", ep, ep]

    # --- 5. Auto-expose PATH dirs under $HOME (read-only) --------------------
    if sandbox.get("auto_expose_path", True):
        for p in detect_home_path_dirs():
            cmd += ["--ro-bind", str(p), str(p)]

    # Extra home read-only dirs from config
    for d in sandbox.get("home_ro_dirs", []):
        full = home_p / d
        if full.exists():
            cmd += ["--ro-bind", str(full), str(full)]

    # --- 5b. Agent-specific home dirs ----------------------------------------
    # Subdirs that §5c will rebind from a scratch dir are skipped here so
    # the real home dir is never exposed, even momentarily.
    scratched_targets: set[str] = {target for _, target in (scratch_binds or [])}

    def _is_scratched(d: str) -> bool:
        return str(home_p / d.lstrip("/").rstrip("/")) in scratched_targets

    for d in agent_cfg.get("home_ro_dirs", []):
        if _is_scratched(d):
            continue
        full = home_p / d
        if full.exists():
            cmd += ["--ro-bind", str(full), str(full)]
    for d in agent_cfg.get("home_rw_dirs", []):
        if _is_scratched(d):
            continue
        full = home_p / d
        full.mkdir(parents=True, exist_ok=True)
        cmd += ["--bind", str(full), str(full)]

    # --- 5c. Ephemeral scratch binds (rsync-seeded in cmd_run) ---------------
    for scratch_path, target in scratch_binds or []:
        cmd += ["--bind", scratch_path, target]

    # --- 6. Project directory (read-write) — AFTER ro mounts so it wins ------
    project = str(project_dir.resolve())
    cmd += ["--bind", project, project]

    # --- 7. Claude config (read-write) ----------------------------------------
    # If `.claude` or `.claude.json` are scratched (paranoid via
    # scratch_home_dirs / scratch_home_files), skip these binds — the
    # ephemeral scratch mount in §5c already covers them and we must not
    # let a later --bind override the scratch.
    claude_dir_target = f"{home}/.claude"
    claude_json_target = f"{home}/.claude.json"
    claude_dir_scratched = claude_dir_target in scratched_targets
    claude_json_scratched = claude_json_target in scratched_targets
    if claude_conf.get("use_real_config", False):
        # Mount real ~/.claude and ~/.claude.json directly (writable).
        # Note: use_real_config is a claude-only knob and is honored only
        # for normal/permissive sandbox levels. Paranoid bypasses this
        # branch via scratch_home_dirs / scratch_home_files (see §5c).
        if not claude_dir_scratched:
            real_claude = str(Path.home() / ".claude")
            if os.path.isdir(real_claude):
                cmd += ["--bind", real_claude, claude_dir_target]
        if not claude_json_scratched:
            real_json = Path.home() / ".claude.json"
            if real_json.exists():
                cmd += ["--bind", str(real_json), claude_json_target]
    else:
        # Mount from sandbox copy
        if not claude_dir_scratched:
            cc_dir = str(expand(claude_conf.get("config_dir",
                                                "~/.agent-sandbox/claude-config")))
            cmd += ["--bind", cc_dir, claude_dir_target]
        # Claude runtime state file (~/.claude.json)
        if not claude_json_scratched:
            claude_json = SANDBOX_DIR / "claude.json"
            if claude_json.exists():
                cmd += ["--bind", str(claude_json), claude_json_target]

    # --- 8. Sanitised gitconfig (read-only) ----------------------------------
    gc = SANDBOX_DIR / "gitconfig"
    if gc.exists():
        cmd += ["--ro-bind", str(gc), f"{home}/.gitconfig"]

    # --- 9. Persistent toolchain caches (read-write) -------------------------
    # Skip toolchain mounts that would hide auto-detected PATH dirs.
    # E.g. if ~/.cargo is in PATH and already ro-bound, don't overlay it
    # with an empty writable dir — that would hide cargo/rustc binaries.
    if sandbox.get("persist_toolchains", True):
        tc = SANDBOX_DIR / "toolchains"
        auto_exposed = {str(p) for p in detect_home_path_dirs()} \
            if sandbox.get("auto_expose_path", True) else set()

        for name, target in [("cargo", ".cargo"), ("npm-cache", ".npm"),
                             ("go", ".go"), ("uv-cache", ".uv-cache"),
                             ("uv-tools", ".uv-tools")]:
            mount_point = f"{home}/{target}"
            d = tc / name
            d.mkdir(parents=True, exist_ok=True)

            if mount_point in auto_exposed:
                # Real dir is already mounted read-only (has binaries).
                # Mount only cache subdirs writable so builds can
                # download dependencies without hiding existing tools.
                # Only mount if the subdir already exists on the host
                # (bwrap cannot mkdir inside a read-only parent).
                if target == ".cargo":
                    for sub in ("registry", "git"):
                        host_sub = home_p / target / sub
                        if host_sub.is_dir():
                            sd = d / sub
                            sd.mkdir(parents=True, exist_ok=True)
                            cmd += ["--bind", str(sd), f"{mount_point}/{sub}"]
                # For other tools whose real dir is in PATH, leave the
                # ro-bind as-is (read-only). User can add writable
                # subdirs via extra_rw if needed.
            else:
                cmd += ["--bind", str(d), mount_point]

    # --- 10. Extra read-write dirs (config) -----------------------------------
    for d in sandbox.get("extra_rw", []):
        ep = str(expand(d))
        if os.path.isdir(ep):
            cmd += ["--bind", ep, ep]

    # --- 10b. CLI extra read-only dirs ----------------------------------------
    for d in (extra_ro_cli or []):
        ep = str(expand(d))
        if os.path.isdir(ep):
            cmd += ["--ro-bind", ep, ep]
        else:
            print(f"Warning: --ro directory does not exist, skipping: {d}", file=sys.stderr)

    # --- 10c. CLI extra read-write dirs ---------------------------------------
    for d in (extra_rw_cli or []):
        ep = str(expand(d))
        if os.path.isdir(ep):
            cmd += ["--bind", ep, ep]
        else:
            print(f"Warning: --rw directory does not exist, skipping: {d}", file=sys.stderr)

    # --- 11. Security options ------------------------------------------------
    if sec.get("unshare_pid", True):
        cmd += ["--unshare-pid"]
    if sec.get("new_session", False):
        cmd += ["--new-session"]
    cmd += ["--die-with-parent"]

    # Paranoid network isolation is set up OUTSIDE this function: the caller
    # wraps the bwrap invocation in `unshare -U -n -r` (creating a userns
    # where we have CAP_NET_ADMIN over the new netns), brings up loopback,
    # starts socat to bridge in-netns TCP to the host-side proxy unix socket,
    # then exec's bwrap. bwrap inherits that netns via the default
    # --share-net behavior, so we do nothing here.

    # --- 12. Environment: clearenv + explicit whitelist -----------------------
    cmd += ["--clearenv"]
    cmd += ["--setenv", "HOME", home]
    cmd += ["--setenv", "USER", os.environ.get("USER", "user")]
    cmd += ["--setenv", "SHELL", "/bin/bash"]

    # Build a PATH: sandbox bin (git wrapper) first, then system paths,
    # then auto-detected home tool paths.
    path_parts: list[str] = []
    if sec.get("block_git_push", True):
        path_parts.append(str(SANDBOX_DIR / "bin"))
    path_parts += ["/usr/local/bin", "/usr/bin", "/bin"]
    if sandbox.get("auto_expose_path", True):
        home_top_dirs = detect_home_path_dirs()
        mounted_tops = set(home_top_dirs)
        for p in home_top_dirs:
            # Add bin-like directories from home
            path_parts.append(str(p))
            # Also add common bin subdirectories
            for sub in ("bin",):
                sp = p / sub
                if sp.is_dir() and str(sp) not in path_parts:
                    path_parts.append(str(sp))
        # Also add deeper host PATH entries that fall under mounted
        # top-level dirs (e.g. ~/Applications/apache-maven-3.9.14/bin).
        home_p = Path.home()
        for entry in detect_home_path_entries():
            entry_str = str(entry)
            if entry_str in path_parts:
                continue
            try:
                rel = entry.relative_to(home_p)
            except ValueError:
                continue
            top = home_p / rel.parts[0]
            if top in mounted_tops:
                path_parts.append(entry_str)
    cmd += ["--setenv", "PATH", ":".join(dict.fromkeys(path_parts))]

    # Toolchain env vars
    cmd += ["--setenv", "CARGO_HOME", f"{home}/.cargo"]
    cmd += ["--setenv", "NPM_CONFIG_CACHE", f"{home}/.npm"]
    cmd += ["--setenv", "GOPATH", f"{home}/.go"]
    cmd += ["--setenv", "GOMODCACHE", f"{home}/.go/pkg/mod"]
    cmd += ["--setenv", "UV_CACHE_DIR", f"{home}/.uv-cache"]
    cmd += ["--setenv", "UV_TOOL_DIR", f"{home}/.uv-tools"]

    # --- Wayland env vars (clipboard access for wl-paste) --------------------
    for wl_var in ("WAYLAND_DISPLAY", "XDG_RUNTIME_DIR"):
        val = os.environ.get(wl_var)
        if val is not None:
            cmd += ["--setenv", wl_var, val]

    # User-whitelisted env vars
    for var in env_conf.get("passthrough", []):
        val = os.environ.get(var)
        if val is not None:
            cmd += ["--setenv", var, val]

    # Extra env vars (from base config)
    for var, val in env_conf.get("extra", {}).items():
        cmd += ["--setenv", var, _expand_env_value(val)]

    # Profile env vars (override base values)
    for var, val in prof.get("env", {}).items():
        cmd += ["--setenv", var, _expand_env_value(val)]

    # Agent-specific env vars
    for var, val in agent_cfg.get("env", {}).items():
        cmd += ["--setenv", var, _expand_env_value(val)]

    # Lince agent ID (from --id flag)
    if agent_id:
        cmd += ["--setenv", "LINCE_AGENT_ID", agent_id]

    # --- 12b. Credential proxy env overrides --------------------------------
    # proxy_env contains base URL rewrites, HTTP_PROXY settings, and
    # env var removals (set to empty string to effectively hide API keys).
    if proxy_env:
        for var, val in proxy_env.items():
            cmd += ["--setenv", var, val]

    # --- 13. Separator -------------------------------------------------------
    cmd += ["--"]

    # --- 14. Command to execute ----------------------------------------------
    # Profile can override default_args; fall back to agent config defaults.
    args_source = list(prof.get("default_args", agent_cfg.get("default_args", [])))
    if safe_mode:
        args_source = [a for a in args_source
                       if a != "--dangerously-skip-permissions"]

    # When the agent uses bwrap internally and we are already inside bwrap,
    # append args to disable the agent's inner sandbox to avoid nesting.
    if agent_cfg.get("bwrap_conflict", False):
        disable_args = agent_cfg.get("disable_inner_sandbox_args", [])
        for da in disable_args:
            if da not in args_source:
                args_source.append(da)

    agent_cmd = [agent_cfg["command"]] + args_source + list(agent_extra_args)

    if log_file:
        # Use `script` to record the full terminal session.
        # Fall back to shell redirect if script is not available.
        script_bin = shutil.which("script")
        if script_bin:
            cmd += [script_bin, "-q", "-e", "-c",
                    " ".join(shlex.quote(c) for c in agent_cmd),
                    str(log_file)]
        else:
            # Fallback: wrap with bash and tee
            cmd += ["bash", "-c",
                    " ".join(shlex.quote(c) for c in agent_cmd)
                    + " 2>&1 | tee " + shlex.quote(str(log_file))]
    else:
        cmd += agent_cmd

    return cmd


