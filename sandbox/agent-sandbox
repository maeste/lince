# ---------------------------------------------------------------------------
# Diff / merge helpers
# ---------------------------------------------------------------------------

def _collect_changes(real: Path, sand: Path) -> list[tuple[str, Path]]:
    changes = []
    sand_files = {f.relative_to(sand) for f in sand.rglob("*") if f.is_file()}
    real_files = {f.relative_to(real) for f in real.rglob("*") if f.is_file()} \
                 if real.exists() else set()
    for rel in sorted(sand_files):
        sf = sand / rel
        rf = real / rel
        if rel not in real_files:
            changes.append(("new", rel))
        else:
            try:
                if sf.read_bytes() != rf.read_bytes():
                    changes.append(("modified", rel))
            except (PermissionError, OSError):
                pass
    return changes


def _show_diff(dir_a: Path, dir_b: Path, label_a: str, label_b: str) -> bool:
    files_a = {f.relative_to(dir_a) for f in dir_a.rglob("*") if f.is_file()}
    files_b = {f.relative_to(dir_b) for f in dir_b.rglob("*") if f.is_file()}
    has = False
    for rel in sorted(files_a | files_b):
        fa, fb = dir_a / rel, dir_b / rel
        if rel in files_a and rel not in files_b:
            print(f"--- only in {label_a}: {rel}")
            has = True
        elif rel not in files_a and rel in files_b:
            print(f"+++ only in {label_b}: {rel}")
            has = True
        else:
            if _print_file_diff(fa, fb, f"{label_a}/{rel}", f"{label_b}/{rel}"):
                has = True
    return has


def _print_file_diff(fa: Path, fb: Path, la: str, lb: str) -> bool:
    try:
        a = fa.read_text().splitlines(keepends=True) if fa.exists() else []
        b = fb.read_text().splitlines(keepends=True) if fb.exists() else []
        diff = list(unified_diff(a, b, fromfile=la, tofile=lb))
        if diff:
            for line in diff:
                print(line, end="")
            print()
            return True
    except (UnicodeDecodeError, PermissionError):
        try:
            if fa.stat().st_size != fb.stat().st_size:
                print(f"  binary differ: {la} vs {lb}")
                return True
        except OSError:
            pass
    return False


def _pretty_print_cmd(cmd: list[str]) -> None:
    """Print a bwrap command in readable multi-line form."""
    i = 0
    while i < len(cmd):
        if cmd[i] == "--":
            print("  --")
            i += 1
            if i < len(cmd):
                print(f"  {' '.join(shlex.quote(c) for c in cmd[i:])}")
            break
        tok = cmd[i]
        if tok.startswith("--"):
            parts = [tok]
            i += 1
            while i < len(cmd) and not cmd[i].startswith("--"):
                parts.append(shlex.quote(cmd[i]))
                i += 1
            print(f"  {' '.join(parts)} \\")
        else:
            print(f"  {shlex.quote(tok)} \\")
            i += 1


