def _snapshot_diff_section(
    label: str,
    snapshot_base: Path,
    current_dir: Path,
    timestamps: list[str],
    exclude: list[str] | None = None,
) -> None:
    """Show diff for a single section (project or config)."""
    if not timestamps:
        snap = _latest_snapshot(snapshot_base)
        if snap is None:
            print(f"{label}: no snapshots found.")
            return
        print(f"{label} diff: {snap.name} vs current\n")
        diff_results = compute_dir_diff(
            snap, current_dir, exclude=exclude,
        )
        has_diff = print_dir_diff(
            diff_results,
            source_label=f"snapshot:{snap.name}",
            target_label="current",
        )
        if not has_diff:
            print("  No differences.\n")

    elif len(timestamps) == 1:
        snap = _find_snapshot_by_timestamp(
            snapshot_base, timestamps[0],
        )
        if snap is None:
            print(
                f"{label}: snapshot '{timestamps[0]}' not found.",
            )
            return
        print(f"{label} diff: {snap.name} vs current\n")
        diff_results = compute_dir_diff(
            snap, current_dir, exclude=exclude,
        )
        has_diff = print_dir_diff(
            diff_results,
            source_label=f"snapshot:{snap.name}",
            target_label="current",
        )
        if not has_diff:
            print("  No differences.\n")

    elif len(timestamps) >= 2:
        snap_a = _find_snapshot_by_timestamp(
            snapshot_base, timestamps[0],
        )
        snap_b = _find_snapshot_by_timestamp(
            snapshot_base, timestamps[1],
        )
        if snap_a is None:
            print(
                f"{label}: snapshot '{timestamps[0]}' not found.",
            )
            return
        if snap_b is None:
            print(
                f"{label}: snapshot '{timestamps[1]}' not found.",
            )
            return
        print(
            f"{label} diff: {snap_a.name} vs {snap_b.name}\n",
        )
        diff_results = compute_dir_diff(
            snap_a, snap_b, exclude=exclude,
        )
        has_diff = print_dir_diff(
            diff_results,
            source_label=f"snapshot:{snap_a.name}",
            target_label=f"snapshot:{snap_b.name}",
        )
        if not has_diff:
            print("  No differences.\n")


def cmd_snapshot_restore(args) -> None:
    """Interactive restore from a snapshot."""
    config, _ = load_config()
    agent_name = args.agent
    project_dir = Path(args.project).resolve()
    snap_conf = _get_snapshot_config(config)
    timestamp = args.timestamp

    do_project = args.project_flag or (
        not args.config and not args.project_flag
    )
    do_config = args.config or (
        not args.config and not args.project_flag
    )

    if do_project:
        base = _get_project_snapshot_base(project_dir)
        _snapshot_restore_section(
            "Project", base, project_dir, timestamp,
            exclude=snap_conf["project_exclude"],
        )

    if do_config:
        config_dir = _resolve_config_dir(config, agent_name)
        if config_dir is None or not config_dir.exists():
            print(
                f"No config directory for agent '{agent_name}'.",
            )
            return

        # Warn about unmerged sandbox changes
        if agent_name == "claude":
            cc = config.get("claude", {})
            if not cc.get("use_real_config", False):
                real = Path.home() / ".claude"
                sand = SANDBOX_DIR / "claude-config"
                if real.exists() and sand.exists():
                    changes = _collect_changes(real, sand)
                    if changes:
                        print(
                            f"\n  WARNING: {len(changes)}"
                            " unmerged sandbox change(s).",
                        )
                        print(
                            "  Run 'agent-sandbox merge'"
                            " first to avoid losing"
                            " changes.\n",
                        )

        base = _get_config_snapshot_base(agent_name)
        _snapshot_restore_section(
            "Config", base, config_dir, timestamp,
        )


def _snapshot_restore_section(
    label: str,
    snapshot_base: Path,
    current_dir: Path,
    timestamp: str | None,
    exclude: list[str] | None = None,
) -> None:
    """Interactive restore for a single section."""
    if timestamp:
        snap = _find_snapshot_by_timestamp(
            snapshot_base, timestamp,
        )
        if snap is None:
            print(f"{label}: snapshot '{timestamp}' not found.")
            return
    else:
        snap = _latest_snapshot(snapshot_base)
        if snap is None:
            print(f"{label}: no snapshots found.")
            return

    print(f"\n{label} restore from: {snap.name}")
    print(f"  snapshot: {snap}")
    print(f"  target:   {current_dir}\n")

    diff_results = compute_dir_diff(
        snap, current_dir, exclude=exclude,
    )
    changed = [r for r in diff_results if r[1] != "unchanged"]
    if not changed:
        print(f"  {label}: no differences to restore.")
        return

    # Flip semantics for restore display:
    # compute_dir_diff(snapshot, current) gives:
    #   'deleted'  = in snapshot only -> add to current
    #   'created'  = in current only  -> remove from current
    #   'modified' = differs -> overwrite current w/ snapshot
    restore_results: list[tuple[Path, str, list[str]]] = []
    for rel, status, diff_lines in diff_results:
        if status == "unchanged":
            continue
        if status == "deleted":
            restore_results.append((rel, "created", diff_lines))
        elif status == "created":
            restore_results.append((rel, "deleted", diff_lines))
        else:
            restore_results.append((rel, status, diff_lines))

    decisions = interactive_review(
        restore_results, current_dir, snap,
        action_verb="restore",
    )

    applied = 0
    for rel, decision in decisions:
        if decision != "accept":
            continue
        snap_file = snap / rel
        cur_file = current_dir / rel

        if snap_file.exists():
            cur_file.parent.mkdir(parents=True, exist_ok=True)
            shutil.copy2(snap_file, cur_file)
        else:
            if cur_file.exists():
                cur_file.unlink()
        applied += 1
        print(f"    restored: {rel}")

    print(f"\n{label} restore: {applied} file(s) restored.")


def cmd_snapshot_prune(args) -> None:
    """Remove old snapshots beyond the configured max count."""
    config, _ = load_config()
    agent_name = args.agent
    project_dir = Path(args.project).resolve()
    snap_conf = _get_snapshot_config(config)

    do_project = args.project_flag or args.all_types
    do_config = args.config or args.all_types

    if not do_project and not do_config:
        do_project = True
        do_config = True

    if do_project:
        base = _get_project_snapshot_base(project_dir)
        max_count = snap_conf["max_project_snapshots"]
        removed = prune_snapshots(base, max_count)
        print(
            f"Project snapshots: removed {removed}, "
            f"max={max_count}",
        )

    if do_config:
        base = _get_config_snapshot_base(agent_name)
        max_count = snap_conf["max_config_snapshots"]
        removed = prune_snapshots(base, max_count)
        print(
            f"Config snapshots [{agent_name}]: "
            f"removed {removed}, max={max_count}",
        )

